function canAffordBuilding(string buildingName, string buildingTitle, agent palace) is boolean
declare
	integer gold, buildingCost;
	list buildings;
begin	

	//$debugout(911, "Dwarfeh AI: In canAffordBuilding for:", buildingTitle);
	buildingCost = $getBuildingCost ( buildingName, buildingTitle, palace);
	gold = $GetPlayerData ( palace, "gold" );
	
	if (gold >= buildingCost)
		return TRUE;
	else
		return FALSE;
end

function getBuildingCost(string buildingName, string buildingTitle, agent palace) is integer
declare
	integer currentPlayer, buildingCount, counter;
	float maxIntegerNum, buildingCost;
	list buildings;
	agent building;
begin
	//currentPlayer = $GetUnitPlayerNumber ( palace );
	maxIntegerNum = 400000.0;
	$ListObjects ( palace, "building", -1, buildings, #MyPlayer, #NoHiddenMap, #CheckTitles, buildingTitle);
	buildingCount = $ListSize ( buildings );
	
	//$debugout(911, "Dwarfeh AI: In building cost for:", buildingTitle, " and found building count:", buildingCount);
	
	buildingCost = $getBuildingBasePrice(buildingName);
	
	if (buildingCount >= 1)
		begin
			foreach building in buildings do
				begin
					//If we go above MAX_INT game crashes without error. Lets prevent that
					if (buildingCost > (maxIntegerNum / $getBuildingCostMultiplier(buildingName)))
						begin
							//$debugout(911, "Dwarfeh AI: BuildingCost (", buildingCost, ") would be bigger than (", maxIntegerNum, ") with the calculation for max int (", (maxIntegerNum / $getBuildingCostMultiplier(buildingName)), ") this was calculated with below buildings.");
							//$debugout(911, "Dwarfeh AI: BuildingCost (", buildingCost, ") would be bigger than (", maxIntegerNum, ") with the calculation for max int (", (maxIntegerNum / 100.0), ") this was calculated with below buildings.");
							//$debugout(911, "Dwarfeh AI: Terrible bug that would cause game crash (MAX INT). ", buildingTitle, "building name:", buildingName, "buildingCost", buildingCost, "Multiplier:", $getBuildingCostMultiplier(buildingName), "buildings:", buildings);
							buildingCost = maxIntegerNum;
						end
					else
						begin
							buildingCost = buildingCost * $getBuildingCostMultiplier(buildingName) / $getBuildingCostDivisor(buildingName);
							//$debugout(911, "Dwarfeh AI: Increasing building costs for Building title:", buildingTitle, "building name:", buildingName, "buildingCost", buildingCost, "Multiplier:", $getBuildingCostMultiplier(buildingName), "buildings:", buildings);
						end
				end
			
		end
	//$debugout(911, "Dwarfeh AI: getBuildingCost Building title:", buildingTitle, "Building count:", buildingCount, "buildingCost", buildingCost, "buildings:", buildings);
	
	//$debugout(911, "Dwarfeh AI: Cost before blacksmith", buildingName, "as", buildingCost); 
	if ($hasBuiltBlacksmith(palace))
		begin
			$debugout(911, "Dwarfeh AI: Calculating that the blacksmith exists");
			buildingCost = buildingCost * 0.95;
		end
	
	//$debugout(911, "Dwarfeh AI: Returning the price for", buildingName, "as", buildingCost); 
	return buildingCost;
	
end


function hasBuiltBlacksmith(agent palace) is boolean
declare
	list currentBlacksmithList;
	agent building;
	integer buildingCount;
	boolean hasCompletedBlacksmith;
	
begin
	$ListObjects ( palace, "Building", -1, currentBlacksmithList, #MyPlayer, #CheckTitles, "Blacksmith" );
	
	buildingCount = $ListSize ( currentBlacksmithList);
	//$debugout(911, "Dwarfeh AI: Current list of blacksmiths", currentBlacksmithList, "count:", buildingCount);
	hasCompletedBlacksmith = FALSE;
	
	foreach building in currentBlacksmithList do
		begin
			//$debugout(911, "Dwarfeh AI: #ATTRIB_FirstStageBuilt", $getAttribute ( building, #ATTRIB_FirstStageBuilt ), "building level:", building's "level");
			if ($getAttribute ( building, #ATTRIB_FirstStageBuilt ) == 1)
				begin
					//$debugout(911, "Dwarfeh AI: Returning true for blacksmith being built");
					hasCompletedBlacksmith = TRUE;
					//break; Whoops this will actually cause it to break other methods. Lets not use it!
				end
		end
	
	return hasCompletedBlacksmith;
end



function canUpgradeBuilding(agent building, agent palace) is boolean
declare
	list heroesList;
begin
	if (building's "title" == "Blacksmith")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchArmorLevel_2 ) == 1 && $getAttribute ( building, #ATTRIB_ResearchWeaponLevel_2 ) == 1 )
						begin
							return TRUE;
						end
				end
			else if (building's "level" == 2  && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchArmorLevel_3 ) == 1 && $getAttribute ( building, #ATTRIB_ResearchWeaponLevel_3 ) == 1)
						begin
							return TRUE;
						end
				end
		end
	else if (building's "title" == "Marketplace")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchMarketDay ) == 1 && $getAttribute ( building, #ATTRIB_ResearchHealingPotions ) == 1)
						begin
							return TRUE;
						end
				end
			else if (building's "level" == 2 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP)  && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchRingsOfProtection ) == 1)
						begin
							//$DebugOut ( 911, "Returning true to upgrade marketplace to level 3");
							return TRUE;
						end
				end
		end
	else if (building's "title" == "Rogues_Guild")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
						return TRUE;
				end
		end
	else if (building's "title" == "Palace" && building's "subtype" == "Palace")
		begin
			if (building's "level" <= 2)
				begin
					$ListObjects (palace, "Hero", -1, heroesList, #InsideOtherUnits, #MyPlayer);
					//$DebugOut ( 911, "List before removing", heroesList);
					$RemoveTitles ( heroesList, "Gnome" );
					$RemoveTitles ( heroesList, "Peasant" );
					$RemoveTitles ( heroesList, "Tax_Collector" );
					$RemoveTitles ( heroesList, "Palace_Guard" );
					
					//$DebugOut ( 911, "List after removing", heroesList);
					//$DebugOut ( 911, "List size", $ListSize(heroesList));
					
					if (building's "level" == 1 && $ListSize(heroesList) >= 4 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
						begin
							return TRUE;
						end
					else if (building's "level" == 2 && $ListSize(heroesList) >= 12 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
						begin
							return TRUE;
						end
				end
		end
	else if (building's "title" == "Magic_Bazaar")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					//$debugout( 911, "Checking for magic bazaar upgrade for level 1 to level 2");
					if ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_One ) == 1 && $getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Two ) == 1)
						begin
							//$debugout( 911, "returning true that we can upgrade magic bazaar to level 2");
							return TRUE;
						end
				end
			else if (building's "level" == 2 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP)  && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Three ) == 1 && $getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Four ) == 1)
						begin
							return TRUE;
						end
				end
		end
	else if (building's "title" == "SorcerersAbode")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
			else if (building's "level" == 2 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP)  && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
		end		
	else if (building's "title" == "Wizards_Guild")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
			else if (building's "level" == 2 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP)  && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
		end
	else if (building's "title" == "Temple_Agrela")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
			else if (building's "level" == 2 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP)  && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
		end
	else if (building's "title" == "Temple_Dauros")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
			else if (building's "level" == 2 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP)  && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
		end
	else if (building's "title" == "Temple_Fervus")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
			else if (building's "level" == 2 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP)  && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
		end
	else if (building's "title" == "Temple_Krypta")
		begin
			if (building's "level" == 1 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
			else if (building's "level" == 2 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP)  && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
		end
	else if (building's "title" == "Library")
		begin
			//Library doesn't have level so we use MaxHP
			if ($getAttribute (building, #ATTRIB_MaxHP) == 100 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ))
				begin
					return TRUE;
				end
		end
	else if (building's "title" == "GuardHouse")
		begin
			//GuardHouse doesn't have level so we use MaxHP
			if ($getAttribute (building, #ATTRIB_MaxHP) == 200 && $getAttribute (building, #ATTRIB_HP) == $getAttribute (building, #ATTRIB_MaxHP) && $GetPlayerData ( palace, "gold" ) >= $getBuildingUpgradePrice( building, palace ) && $getAttribute ( building, #ATTRIB_ResearchArrows ) == 1)
				begin
					return TRUE;
				end
		end
	else
		begin	
			return FALSE;		
		end
		
end

///////////////////////////////////////////////////////////////////////////////
function performEnemyPlayer2Research(agent palace)
// This function sets the research levels for all of the enemy city buildings at startup.
declare
	list buildings, current;
	agent building;

begin
	//$Debugout ( 911, "Setting enemy research levels." );

	$ListObjects ( palace, "building", -1, buildings, #MyPlayer );

	// Set blacksmith research.
	current = $RemoveTitles ( buildings, "blacksmith" );
	
	//$Debugout ( 911, "current list", current );

	foreach building in current do
		begin
			//TODO: Future scope is to create separate functions for the research.
			// Maybe tie it to the building itself as researchScript and handling it like that would solve this issue. Is that possible?
			//The goal in the future is to actually require time to perform research instead of being instant
			//Research times are already defined in mx_Globals.gpl. Thread would take argument (integer) for attribute
			//This can cause weird issues since threads that use same functions will just reset the timer when called again.
			//Example failure case: 2 blacksmiths trying to research same item will just make them reset before it's done researching. Bleh!
			
			//This function check's the building's level and checks to ensure that it is built
			if (building's "level" >= 1 && $getAttribute ( building, #ATTRIB_FirstStageBuilt ) == 1 && $getTotalHeroLevel(palace) >= 10 && ($getAttribute ( building, #ATTRIB_ResearchArmorLevel_2 ) == 0 || $getAttribute ( building, #ATTRIB_ResearchWeaponLevel_2 ) == 0) )
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchArmorLevel_2 ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostArmorLevel_2)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostArmorLevel_2 );
							$setAttribute ( building, #ATTRIB_ResearchArmorLevel_2, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchWeaponLevel_2 ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostWeaponLevel_2)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostWeaponLevel_2 );
							$setAttribute ( building, #ATTRIB_ResearchWeaponLevel_2, 1 );
						end
				end
			else if (building's "level" >= 2 && $getAttribute ( building, #ATTRIB_currentstagebuilt ) == 1 && $getTotalHeroLevel(palace) >= 20 && ($getAttribute ( building, #ATTRIB_ResearchArmorLevel_3 ) == 0 || $getAttribute ( building, #ATTRIB_ResearchWeaponLevel_3 ) == 0))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchArmorLevel_3 ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostArmorLevel_3)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostArmorLevel_3 );
							$setAttribute ( building, #ATTRIB_ResearchArmorLevel_3, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchWeaponLevel_3 ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostWeaponLevel_3)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostWeaponLevel_3 );
							$setAttribute ( building, #ATTRIB_ResearchWeaponLevel_3, 1 );
						end
				end
			else if (building's "level" == 3 && $getAttribute ( building, #ATTRIB_currentstagebuilt ) == 1 && $getTotalHeroLevel(palace) >= 30 && ($getAttribute ( building, #ATTRIB_ResearchArmorLevel_4 ) == 0 || $getAttribute ( building, #ATTRIB_ResearchWeaponLevel_4 ) == 0) )
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchArmorLevel_4 ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostArmorLevel_4)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostArmorLevel_4 );
							$setAttribute ( building, #ATTRIB_ResearchArmorLevel_4, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchWeaponLevel_4 ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostWeaponLevel_4)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostWeaponLevel_4 );
							$setAttribute ( building, #ATTRIB_ResearchWeaponLevel_4, 1 );
						end
				end
		end

	// Set marketplace research.
	current = $RemoveTitles ( buildings, "marketplace" );

	foreach building in current do
		
		begin
			if (building's "level" >= 1 && $getAttribute ( building, #ATTRIB_FirstStageBuilt ) == 1 && ($getAttribute ( building, #ATTRIB_ResearchMarketDay ) == 0 || $getAttribute ( building, #ATTRIB_ResearchHealingPotions ) == 0))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchMarketDay ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostMarketDay)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostMarketDay );
							$setAttribute ( building, #ATTRIB_ResearchMarketDay, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchHealingPotions ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostHealPotions)
						begin
							//$Debugout ( 911, "researching healing potions");
							$adjustPlayerData ( palace, "gold", -#ResearchCostHealPotions );
							$setAttribute ( building, #ATTRIB_ResearchHealingPotions, 1 );
						end
				end
			else if (building's "level" >= 2 && $getAttribute ( building, #ATTRIB_currentstagebuilt ) == 1 && $getAttribute ( building, #ATTRIB_ResearchRingsOfProtection ) == 0)
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchRingsOfProtection ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostRingsofProtection)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostRingsofProtection);
							$setAttribute ( building, #ATTRIB_ResearchRingsOfProtection, 1 );
						end
				end
			else if (building's "level" == 3 && $getAttribute ( building, #ATTRIB_currentstagebuilt ) == 1 && $getTotalHeroLevel(palace) >= 100 && $getAttribute ( building, #ATTRIB_ResearchPowerfulItem ) == 0)
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchPowerfulItem ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostPowerfulItem)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostPowerfulItem);
							$setAttribute ( building, #ATTRIB_ResearchPowerfulItem, 1 ); // this is the amulet. :P
						end
				end
		end


	// Set magic bazaar research.
	current = $RemoveTitles ( buildings, "Magic_Bazaar" );

	foreach building in current do
		begin
			if (building's "level" >= 1 && $getAttribute ( building, #ATTRIB_FirstStageBuilt ) == 1 && $getTotalHeroLevel(palace) >= 10 && ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_One ) == 0 || $getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Two ) == 0))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_One ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostMagicBazaar_Item_One)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostMagicBazaar_Item_One);
							$setAttribute ( building, #ATTRIB_ResearchBazaar_Item_One, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Two ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostMagicBazaar_Item_Two)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostMagicBazaar_Item_Two);
							$setAttribute ( building, #ATTRIB_ResearchBazaar_Item_Two, 1 );
						end
				end
			else if (building's "level" >= 2 && $getAttribute ( building, #ATTRIB_currentstagebuilt ) == 1 && $getTotalHeroLevel(palace) >= 20 && ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Three ) == 0 || $getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Four ) == 0))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Three ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostMagicBazaar_Item_Three)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostMagicBazaar_Item_Three);
							$setAttribute ( building, #ATTRIB_ResearchBazaar_Item_Three, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Four ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostMagicBazaar_Item_Four)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostMagicBazaar_Item_Four);
							$setAttribute ( building, #ATTRIB_ResearchBazaar_Item_Four, 1 );
						end
				end
			else if (building's "level" >= 3 && $getAttribute ( building, #ATTRIB_currentstagebuilt ) == 1 && $getTotalHeroLevel(palace) >= 30 && ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Five ) == 0 || $getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Six ) == 0))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Five ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostMagicBazaar_Item_Five)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostMagicBazaar_Item_Five);
							$setAttribute ( building, #ATTRIB_ResearchBazaar_Item_Five, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchBazaar_Item_Six ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostMagicBazaar_Item_Six)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostMagicBazaar_Item_Six);
							$setAttribute ( building, #ATTRIB_ResearchBazaar_Item_Six, 1 );
						end
				end		
		end

	// Set guardhouse research.
	current = $RemoveTitles ( buildings, "guardhouse" );

	foreach building in current do
		begin
			//Guardhouse does not have levels so we base it on their maxhp to determine their level
			if ($getAttribute ( building, #ATTRIB_FirstStageBuilt ) >= 1 && $getAttribute( building ,#attrib_MAXHP) >= 200 && $getAttribute ( building, #ATTRIB_ResearchArrows ) == 0)
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchArrows ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostArrows)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostArrows);
							$setAttribute ( building, #ATTRIB_ResearchArrows, 1 );
						end
				end
			else if ($getAttribute ( building, #ATTRIB_currentstagebuilt ) == 1 && $getAttribute( building ,#attrib_MAXHP) == 275 && $getAttribute ( building, #ATTRIB_ResearchGoodGuard ) == 0)
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchGoodGuard ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostGoodGuard)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostGoodGuard);
							$setAttribute ( building, #ATTRIB_ResearchGoodGuard, 1 );
						end
				end
		end

	// Set fairgrounds research and activate the building.
	current = $RemoveTitles ( buildings, "fairgrounds" );

	foreach building in current do
		begin
			if ($getAttribute ( building, #ATTRIB_FirstStageBuilt ) == 1 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostTournament)
				begin
					$adjustPlayerData ( palace, "gold", -#ResearchCostTournament);
					$setAttribute ( building, #ATTRIB_ResearchTournament, 1 );
					$setAttribute ( building, #ATTRIB_CurrentEvent, 4 );				
				end

		end


	// Set library research
	current = $ListTitles ( buildings, "library" );

	foreach building in current do
		begin
			//Library does not have levels so we base it on their maxhp to determine their level
			if ($getAttribute ( building, #ATTRIB_FirstStageBuilt ) >= 1 && $getAttribute( building ,#attrib_MAXHP) >= 100 && ($getAttribute ( building, #ATTRIB_ResearchTrainIntelligence ) == 0 || $getAttribute ( building, #ATTRIB_ResearchMagicResistance ) == 0 || $getAttribute ( building, #ATTRIB_ResearchWizardFireBlast ) == 0))
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchTrainIntelligence ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostTrainIntelligence)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostTrainIntelligence);
							$setAttribute ( building, #ATTRIB_ResearchTrainIntelligence, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchMagicResistance ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostMagicResistance)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostMagicResistance);
							$setAttribute ( building, #ATTRIB_ResearchMagicResistance, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchWizardFireBlast ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostWizardFireBlast)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostWizardFireBlast);
							$setAttribute ( building, #ATTRIB_ResearchWizardFireBlast, 1 );
						end
				end
			else if ($getAttribute ( building, #ATTRIB_currentstagebuilt ) == 1 && $getAttribute( building ,#attrib_MAXHP) == 200)
				begin
					if ($getAttribute ( building, #ATTRIB_ResearchWizardMeteorStorm ) == 0  && $GetPlayerData ( palace, "gold" ) >= #ResearchCostWizardMeteorStorm)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostWizardMeteorStorm);
							$setAttribute ( building, #ATTRIB_ResearchWizardMeteorStorm, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchEnergyBlast ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostEnergyBlast)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostEnergyBlast);
							$setAttribute ( building, #ATTRIB_ResearchEnergyBlast, 1 );
						end
					if ($getAttribute ( building, #ATTRIB_ResearchFireShield ) == 0 && $GetPlayerData ( palace, "gold" ) >= #ResearchCostFireShield)
						begin
							$adjustPlayerData ( palace, "gold", -#ResearchCostFireShield);
							$setAttribute ( building, #ATTRIB_ResearchFireShield, 1 );
						end
				end
		end

end

///////////////////////////////////////////////////////////////////////////////
function Check_Lightning_Defense () is boolean
// This function lets a non-player kindgom look for enemy heroes intruding within it's
// wizard's guild cast radius.  It checks the closest enemy, and if it detects a cluster
// of them within range, it will fry them all with a lightning storm. Otherwise it will
// smack the single target with a lightning bolt.

declare
	agent palace, hero, zaptarget, building, guild;
	list enemy_heroes, buildings;
	boolean flag;
	integer gold;

begin

	$Debugout ( 911, "Checking for Lightning Storm." );

	palace = $Dwarfeh_GetPlayerTwoPalace ();

	// build list of wizguilds.
	$ListObjects ( palace, "building", -1, buildings, #CheckTitles, "Wizards_Guild", #MyPlayer, #NoHiddenMap );

	// Check to make sure if you have a valid guild of the level required.
	flag = FALSE;
	if ( $ListSize ( buildings ) > 0 )
		begin
			foreach building in buildings do
				begin
					if ( building's "level" >= 2 )
						begin
							flag = TRUE;
							guild = building;
						end
				end
		end

	// If no valid guild has been found, the function will cease here.
	if ( flag == FALSE )
		return FALSE;

	// Build a list of enemy heroes in range of guild.
	$ListObjects ( guild, "hero", 1200, enemy_heroes, #NotMyPlayer, #NoHiddenMap );

	// Target the closest hero, if any.
	if ( $ListSize ( enemy_heroes ) > 0 )
		begin
			ZapTarget = $ListMember ( enemy_heroes, 1 );
			$ListObjects ( ZapTarget, "hero", 150, enemy_heroes, #MyPlayer, #NoHiddenMap );
			// if there is MORE than one other hero (three total) within storm radius,
			// blast them with a lightning storm.
			if ( $ListSize ( enemy_heroes ) > 1 )
				begin
					$CreateSpellUnit ( guild, "Lightning_Storm", ZapTarget );
					$AdjustPlayerData ( palace, "gold", -1600 );

					gold = $GetPlayerData ( palace, "gold" );
					$DebugOut ( 911, "AI lightning stormed ", ZapTarget, ". ", gold, " gold remaining." );
					return TRUE; // AI may NOT consider another action after throwing storm.
				end
  			else // Otherwise hit the one guy with a lightning bolt instead.
				begin
					if (( $RandomNumber ( 4 ) + 1 ) > 2 )
						begin
							$AdjustPlayerData ( palace, "gold", -400 );
							$lightning_bolt_hit ( ZapTarget );

							gold = $GetPlayerData ( palace, "gold" );
							$DebugOut ( 911, "AI lightning bolted ", ZapTarget, ". ", gold, " gold remaining." );
							Return FALSE; // AI MAY consider another action after throwing a bolt.
						end
				end
		end
	// If the function falls through to here, no valid targets were found.
	return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function AI_Check_Resurrect (agent palace)
// This function lets a non-player kindgom look for friendly dead heroes and evaluate
// them as targets for an agrella resurrect spell.  It will not work if the player
// does not control a level 3 agrella temple. The function will return TRUE if
// it resurrects someone, FALSE otherwise.
declare
	agent hero, restarget, building;
	list heroes, dead_heroes, buildings;
	boolean hasKrypta, hasAgrela;
	integer gold, costToRevive;

begin
	hasKrypta = FALSE;
	hasAgrela = FALSE;

	//$Debugout ( 911, "Checking for resurrection." );

	// build list of temples.
	$ListObjects ( palace, "building", -1, buildings, #CheckTitles, "Temple_Krypta", #MyPlayer );

	// Make sure a valid level 3 temple is available.
	
	if ( $ListSize ( buildings ) > 0 )
		begin
			foreach building in buildings do
				begin
					if ( building's "level" == 3 )
						begin
							hasKrypta = TRUE;
							costToRevive = 2000;
						end
				end
		end
	
	$ListObjects ( palace, "building", -1, buildings, #CheckTitles, "Temple_Agrela", #MyPlayer );
	
	if ( $ListSize ( buildings ) > 0 )
		begin
			foreach building in buildings do
				begin
					if ( building's "level" == 3 )
						begin
							hasAgrela = TRUE;
							costToRevive = 1500;
						end
				end
		end

	// If no valid temple has been found, the function will cease here.
	if ( hasKrypta == FALSE && hasAgrela == FALSE )
		return;

	// Build a list of dead heroes.
	$ListObjects ( palace, "dead", -1, dead_heroes, #MyPlayer, #NoHiddenMap );

	foreach hero in dead_heroes do
		begin
			if ( $IsDead ( hero ) == FALSE )
				dead_heroes -= hero;
		end

	// Sort through the list of dead heroes, choose the highest level dead hero.
	if ( $ListSize ( dead_heroes ) > 0 )
		begin
			ResTarget = $ListMember ( dead_heroes, 1 );
			foreach hero in dead_heroes do
				begin
				//	if ( $GetAttribute ( hero, #ATTRIB_ExperienceLevel ) > $GetAttribute ( ResTarget, #ATTRIB_ExperienceLevel ))
				//		ResTarget = hero;
				//end
					// If that hero is >= level 10, then resurrect him.
					if ( $GetAttribute ( hero, #ATTRIB_ExperienceLevel ) >= 10 )
						begin
							if (hasKrypta && $GetPlayerData ( palace, "gold" ) >= 2000)
								begin
									$Reanimate_Begin ( hero );
									$AdjustPlayerData ( palace, "gold", -2000 );

									gold = $GetPlayerData ( palace, "gold" );
									//$DebugOut ( 911, "AI Resurrected ", hero, ". ", gold, " gold remaining." );
								end
							else if (hasAgrela && $GetPlayerData ( palace, "gold" ) >= 1500)
								begin
									$Resurrection_Begin ( hero );
									$AdjustPlayerData ( palace, "gold", -1500 );

									gold = $GetPlayerData ( palace, "gold" );
									//$DebugOut ( 911, "AI Resurrected ", hero, ". ", gold, " gold remaining." );								
								end
						end
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function Check_Heal () is boolean
// This function lets a non-player kindgom look for friendly heroes and evaluate
// them as targets for an agrella heal spell.  It will not work if the player
// does not control a level 1 or higher agrella temple. The function will return TRUE if
// it heals someone, FALSE otherwise.
declare
	agent palace, hero, HealTarget, building;
	list heroes, buildings;
	boolean flag;
	integer gold;

begin

	$Debugout ( 911, "Checking for heal." );

	palace = $Dwarfeh_GetPlayerTwoPalace ();

	// First build a list of temples and make sure at least one level three temple
	// is under the AI player's control.
	$ListObjects ( palace, "building", -1, buildings, #CheckTitles, "Temple_Fervus", #MyPlayer, #NoHiddenMap );

	// If no valid temple has been found, the function will cease here.
	if ( $ListSize ( buildings ) < 1 )
		Return FALSE;

	// Build a list of heroes.
	$ListObjects ( palace, "hero", -1, heroes, #MyPlayer, #NoHiddenMap );

	// Sort through the list of heroes, choose an injured hero.
	if ( $ListSize ( heroes ) > 0 )
		begin
			flag = FALSE;
			foreach hero in heroes do
				begin
					if ( $IsDead ( hero ) == FALSE )
						begin
							if ( $GetAttribute ( hero, #ATTRIB_HP ) < ( $GetAttribute ( hero, #ATTRIB_MaxHP ) * 0.5 ))
								begin
									HealTarget = hero;
									flag = TRUE;
								end
						end
				end
			// If a valid hero was found, heal him.
			if ( flag == TRUE )
				begin
					$Fervus_Heal_Effect ( HealTarget );
					$AdjustPlayerData ( palace, "gold", -400 );

					gold = $GetPlayerData ( palace, "gold" );
					$DebugOut ( 911, "AI Healed ", HealTarget, ". ", gold, " gold remaining." );
					return TRUE;
				end
		end
	// If the function falls through to here, no valid heal target was found.
	return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function AI_Post_Enemy_Reward (agent palace)
// Causes the AI player to decide whether or how to place a reward flag.
declare
	agent target, hero;
	integer random, total_level, avg_level, num_heroes;
	list heroes, tempheroes;


begin
	//$Debugout ( 911, "Checking for reward flag targets." );

	if ( $CountPlacedFlags ( palace ) < 2 ) // Only consider if 2 are not placed
		begin
			total_level = $getTotalHeroLevel(palace);
			if (( $randomnumber ( 100 ) + 1 ) <  total_level ) // Decide if you have enough levels to attack with.
				begin
					random = $RandomNumber ( 3 ) + 1; // Randomly choose a target type and flag it.
					if ( random == 1 )
						$AI_FlagEconomicTarget ( total_level, palace );
					else if ( random == 2 )
						$AI_FlagGuildTarget ( total_level, palace );
					else if ( random == 3 )
						$AI_FlagClosestBuilding ( total_level, palace );

				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function CountPlacedFlags ( agent palace ) is integer
// Returns the number of reward flags currently in play belonging to the agent's player.
declare
	list flags;
	integer number;
begin
	$listobjects ( palace, "RewardFlag", -1, flags, #Rewardflags, #Myplayer, #NoHiddenMap );
	number = $ListSize ( flags );
	return number;
end

///////////////////////////////////////////////////////////////////////////////
function AI_FlagEconomicTarget ( integer levels, agent palace ) is agent
// This function will cause a computer player to place a reward flag on the closest enemy marketplace or trade post.
declare
	agent target, flagtarget, flag, AIRootAgent;
	list t1, t2, targets, buildings;
	integer distance, newdistance, gold;

begin
	//$Debugout ( 911, "Flagging Economic Target." );

	// Build  a list of all markets and tradeposts.
	$ListObjects ( palace, "building", -1, buildings, #NotMyTeam );
	t1 = $RemoveTitles ( buildings, "marketplace" );
	t2 = $ListTitles ( buildings, "trading_post" );
	targets = $AddLists ( t1, t2 );
	
	if ( $ListSize ( targets ) == 0 )
		begin
			//Assume economic targets have all been destroyed and they are struggling. Go for the kill
			t1 = $ListTitles ( buildings, "Outpost" );
			t2 = $ListTitles ( buildings, "Palace" );
			targets = $AddLists ( t1, t2 );
		end
		
	if ( $ListSize ( targets ) == 0 )
		begin
			//Not seeing anything resourceful near us. Lets attack the nearest
			$AI_FlagClosestBuilding( levels, palace );
		end
	
	// Select the closest item on the list.
	if ( $ListSize ( targets ) > 0 )
		begin
			flagtarget = $ListMember ( targets, 1 );
			distance = $DistanceBetweenAgents ( palace, flagtarget );

			foreach target in targets do
				begin
					newdistance = $DistanceBetweenAgents ( palace, target );
					if ( newdistance < distance )
						begin
							flagtarget = target;
							distance = newdistance;
						end
				end

			AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

			// Set the flag value based on the power of the computer player's heroes.
			if ( levels < 30 && $GetPlayerData ( palace, "gold" ) >= 100 )
				begin
					gold = 100;
					palace's "flag_value" = gold;
				end
			else if ( levels < 45 && $GetPlayerData ( palace, "gold" ) >= 200)
				begin
					gold = 200;
					palace's "flag_value" = gold;
				end
			else if ( levels < 55 && $GetPlayerData ( palace, "gold" ) >= 300 )
				begin
					gold = 300;
					palace's "flag_value" = gold;
				end
			else if ( levels < 65 && $GetPlayerData ( palace, "gold" ) >= 400 )
				begin
					gold = 400;
					palace's "flag_value" = gold;
				end
			else if ( levels < 75 && $GetPlayerData ( palace, "gold" ) >= 500 )
				begin
					gold = 500;
					palace's "flag_value" = gold;
				end
			else if ( levels >= 75 && $GetPlayerData ( palace, "gold" ) >= #AI_max_reward_flag)
				begin
					gold = #AI_max_reward_flag;
					palace's "flag_value" = #AI_max_reward_flag;
				end

			// Place the flag if the target is valid.
			if ( $IsValidGamePiece ( flagtarget ) && gold > 0)
				flag = $PlaceRewardFlag ( flagtarget, $GetUnitPlayerNumber(palace), gold );

			if ( flag != $nullagent ())
				palace's "AI_Reward_Flags" << flag;

			gold = $GetPlayerData ( palace, "gold" );
			$DebugOut ( 911, "AI Flagged ", flagtarget, ". ", gold, " gold remaining." );
		end
	else
		$DebugOut ( 911, "AI unable to find appropriate flag target." );
end

