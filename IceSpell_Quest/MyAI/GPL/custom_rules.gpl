///////////////////////////////////////////////////////////////////////////////
function AI_Flag_Remover (agent palace)
// Each time this function runs, it takes the first flag on the AIRootAgent's list
// (the oldest), and checks the status of the agent it is attached to. If that agent is
// in full repair it assumes that it has been unable to attack it effectively and
// removes the flag.
declare
	agent flag, target, AIRootAgent;
	list flags;

begin
	flags = palace's "AI_Reward_Flags";

	if ( $ListSize ( flags ) > 0 )
		begin
			flag = $ListMember ( flags, 1 );
			if ( $IsValidGamePiece ( flag ) )
				begin
					target = $AgentNumber ( $GetAttribute ( flag, #ATTRIB_TargetID ));
					if ( $GetAttribute ( target, #ATTRIB_HP ) == $GetAttribute ( target, #ATTRIB_MaxHP ) )
						begin
							$deletegamepiece ( flag );
							palace's "AI_Reward_Flags" -= flag;
						end
				end
			else
				$Dwarfeh_AI_cleanupOldFlags(palace);
		end
end

function Dwarfeh_AI_cleanupOldFlags(agent palace)
// Each time this function runs, it removes all old game flags
declare
	agent flag, target, AIRootAgent;
	list flags;

begin
	flags = palace's "AI_Reward_Flags";

	if ( $ListSize ( flags ) > 0 )
		begin
			foreach flag in flags do
				begin
					if ( $IsValidGamePiece ( flag ) == false )
						begin
							palace's "AI_Reward_Flags" -= flag;
						end
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function End_Flag_Remover ()
// This function removes any and all flags active when the game ends.
declare
	agent flag, palace;
	list flags;

begin
	palace = $Dwarfeh_GetPlayerOnePalace ();

	$ListObjects ( palace, "RewardFlag", -1, flags, #RewardFlags );

	foreach flag in flags do
		begin
			$deletegamepiece ( flag );
		end
end

//This deals with searching for the outpost, so the player transitions to it as their seat-of-power rather than losing
//when the palace dies
//It is also run by the Outpost if there are no palaces left on the map that belong to the local player
function Palace_Death ( agent ThisAgent )

declare
	agent AIRootAgent;
	integer gold;
	list flags, Outposts;
	agent	flag, Outpost;
	boolean startAI;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	startAI = FALSE;
	

	if ($isRunning(ThisAgent's "playerAI_build"))
		begin
			$KillThread ( ThisAgent's "playerAI_build" );
			$KillThread ( ThisAgent's "playerAI_resurrect" );
			$KillThread ( ThisAgent's "playerAI_guild_recruit" );
			$KillThread ( ThisAgent's "playerAI_research" );
			$KillThread ( ThisAgent's "playerAI_building_upgrade" );
			$KillThread ( ThisAgent's "playerAI_flag_adder" );
			$KillThread ( ThisAgent's "playerAI_flag_remover" );
			startAI = TRUE;
		end

  	thisagent's "type" = "Dead";

	
	$Dump_Contained_Units (ThisAgent);

	$performaction( thisagent,"Become_Rubble",thisagent );

	//Find the outposts
	$ListObjects (ThisAgent, "Building", -1, Outposts, #MyPlayer, #CheckSubtypes, "Outpost", #ATTRIB_FirstStageBuilt, 1);

	If ($ListSize (Outposts) > 0)
		begin

			Outpost = $ListMember (Outposts, 1);

			//Set the outpost as the new palace so it gets returned by $ListPalaces ();
			//Make sure to set it as ThisAgent's player number's palace
			if (startAI)
				begin
					$AddAttribute(Outpost, "build_gnomes", "boolean", ThisAgent's "build_gnomes");
					$AddAttribute(Outpost, "build_elves", "boolean", ThisAgent's "build_elves");
					$AddAttribute(Outpost, "build_dwarves", "boolean", ThisAgent's "build_dwarves");
					$AddAttribute(Outpost, "build_agrela", "boolean", ThisAgent's "build_agrela");
					$AddAttribute(Outpost, "build_krypta", "boolean", ThisAgent's "build_krypta");
					$AddAttribute(Outpost, "build_krolm", "boolean", ThisAgent's "build_krolm");
					$AddAttribute(Outpost, "build_helia", "boolean", ThisAgent's "build_helia");
					$AddAttribute(Outpost, "build_lunord", "boolean", ThisAgent's "build_lunord");			
					$AddAttribute(Outpost, "flag_value", "integer", ThisAgent's "flag_value");
					$AddAttribute(Outpost, "AI_Reward_Flags", "list", ThisAgent's "AI_Reward_Flags");
				end
			
			$SetPalace (Outpost, $GetUnitPlayerNumber (ThisAgent) );

			//Change "Title" to palace, so $GetTruePalace starts to return the Outpost
			Outpost's "Title" = "Palace";

			$Transfer_Palace_Data (ThisAgent, Outpost);
			
			//Restart AI threads
			if (startAI)
				begin
					$debugout(911, "Dwarfeh AI: Starting AI back up because we have an outpost");
					$AddAttribute(Outpost, "playerAI_build", "function", $enemyPlayer2Build);
					$AddAttribute(Outpost, "playerAI_resurrect", "function", $AI_Check_Resurrect);
					$AddAttribute(Outpost, "playerAI_guild_recruit", "function", $enemyPlayer2GuildSpawn);
					$AddAttribute(Outpost, "playerAI_research", "function", $performEnemyPlayer2Research);
					$AddAttribute(Outpost, "playerAI_building_upgrade", "function", $performEnemyPlayer2BuildingUpgrade);
					$AddAttribute(Outpost, "playerAI_flag_adder", "function", $AI_Post_Enemy_Reward);
					$AddAttribute(Outpost, "playerAI_flag_remover", "function", $AI_Flag_Remover);
				
					
					$NewThread ( Outpost's "playerAI_build", ( 1000 ), Outpost);
					$NewThread ( Outpost's "playerAI_resurrect", ( 15000 ), Outpost);
					$NewThread ( Outpost's "playerAI_guild_recruit", ( 30000 ), Outpost);
					$NewThread ( Outpost's "playerAI_research", ( 60000 ), Outpost);
					$NewThread ( Outpost's "playerAI_building_upgrade", ( 45000 ), Outpost);
					$NewThread ( Outpost's "playerAI_flag_adder", ( 30000 ), Outpost);
					$NewThread ( Outpost's "playerAI_flag_remover", ( 90000 ), Outpost);	
				end			

		end

	Else
		begin
			gold = $getplayerdata ( thisagent,"gold" );
			$adjustplayerdata ( thisagent, "gold", 0 - gold );
			$dropgoldeveryone ( thisagent, gold );

			$Player_Dead_Cleanup ( thisagent );

			$declareloss ( thisagent );

		end

	$deleteagent(thisagent);

end

///////////////////////////////////////////////////////////////////////////////
//Dwarfeh
//This was updated to remove AutoBuilding's as well - sewers and graveyards
function Player_Dead_Cleanup ( agent thisagent )
// This function removes flags and destroys all buildings belonging to the player.
declare
	agent unit, palace;
	list units;

begin

	$listobjects ( thisagent, "rewardFlag", -1, units, #rewardflags, #Myplayer, #NoHiddenMap );
	foreach unit in units do
		begin
			$deletegamepiece ( unit );
		end

	$ListObjects ( thisagent, "building", -1, units, #Myplayer, #NoHiddenMap );
	foreach unit in units do
		begin
			if ( $IsDead ( unit ) == FALSE )
				$SetAttribute ( unit, #ATTRIB_HP, -1 );
		end

	$ListObjects ( thisagent, "lair", -1, units, #Myplayer, #NoHiddenMap );
	foreach unit in units do
		begin
			if ( $IsDead ( unit ) == FALSE )
				( unit's "IGDeathScript" )( unit );
		end
		
	$ListObjects ( thisagent, "AutoBuilding", -1, units, #Myplayer, #NoHiddenMap );
	foreach unit in units do
		begin
			if ( $IsDead ( unit ) == FALSE )
				( unit's "IGDeathScript" )( unit );
		end		
		
end