//This returns the cost to upgrade the current building to the next level
function getBuildingUpgradePrice(agent building, agent palace) is integer
declare
	integer buildingUpgradeCost;

begin
	if (building's "title" == "SorcerersAbode")
			begin
				if (building's "level" == 1)
					begin
						buildingUpgradeCost = 2500;
					end
				else if (building's "level" == 2)
					begin
						buildingUpgradeCost = 3000;
					end
			end
	else if (building's "title" == "Magic_Bazaar")
			begin
				if (building's "level" == 1)
					begin
						buildingUpgradeCost = 1200;
					end
				else if (building's "level" == 2)
					begin
						buildingUpgradeCost = 1200;
					end
			end
	else if (building's "title" == "Palace")
		begin		
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 3000;
				end
			else if (building's "level" == 2)
				begin
					buildingUpgradeCost = 3750;
				end
		end		
	else if (building's "title" == "Blacksmith")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 600;
				end
			else if (building's "level" == 2)
				begin
					buildingUpgradeCost = 800;
				end
		end
	else if (building's "title" == "GuardHouse")
		begin
			//guardhouse doesn't have levels so we base it on their maxhp
			if ($getAttribute( building ,#attrib_MAXHP) == 200)
				begin
					buildingUpgradeCost = 500;
				end
		end
	else if (building's "title" == "Library")
		begin
			//Library doesn't have levels so we base it on their maxhp
			if ($getAttribute( building ,#attrib_MAXHP) == 100)
				begin
					buildingUpgradeCost = 800;
				end
		end
	else if (building's "title" == "Marketplace")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 1000;
				end
			else if (building's "level" == 2)
				begin
					buildingUpgradeCost = 1000;
				end
		end
	else if (building's "title" == "Rogues_Guild")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 850;
				end
		end
	else if (building's "title" == "Wizards_Guild")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 2500;
				end
			else if (building's "level" == 2)
				begin
					buildingUpgradeCost = 3500;
				end
		end
	else if (building's "title" == "Temple_Agrela")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 1500;
				end
			else if (building's "level" == 2)
				begin
					buildingUpgradeCost = 2600;
				end
		end
	else if (building's "title" == "Temple_Dauros")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 2200;
				end
			else if (building's "level" == 2)
				begin
					buildingUpgradeCost = 3400;
				end
		end
	else if (building's "title" == "Temple_Fervus")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 1300;
				end
			else if (building's "level" == 2)
				begin
					buildingUpgradeCost = 2500;
				end
		end	
	else if (building's "title" == "Temple_Helia")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 2000;
				end
		end	
	else if (building's "title" == "Temple_Krypta")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 1800;
				end
			else if (building's "level" == 2)
				begin
					buildingUpgradeCost = 2200;
				end
		end
	else if (building's "title" == "Temple_Lunord")
		begin
			if (building's "level" == 1)
				begin
					buildingUpgradeCost = 2000;
				end
		end
	else
		begin
			$debugout(911, "Dwarfeh AI: ERROR: Unable to find the upgrade price for", building's "title");
			buildingUpgradeCost = 100;
		end

	if ($hasBuiltBlacksmith(palace))
		begin
			//$debugout(911, "Dwarfeh AI: Calculating that the blacksmith exists");
			buildingUpgradeCost = buildingUpgradeCost * 19 / 20;
		end
	
	return buildingUpgradeCost;

end

