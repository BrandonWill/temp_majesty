function basicAI()
declare
	agent AIRootAgent;
	agent palace, enemypalace;
	list palaces;
	function player2AI;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	
	//$RevealWholeMap( #player_1 );

	palace = $Dwarfeh_GetPlayerOnePalace ();
	EnemyPalace = $Dwarfeh_GetPlayerTwoPalace();

	$Setup_Quest_Music ( AiRootAgent );
	//Start playing music

	// what can't be used in this quest?
	

	// setup starting messages

	// setup special things
	
	/////////////////////////////////////////////////////////////////////////
	AIRootAgent's "Quest_Number" = #QNumber_Last_Palace;

	AIRootAgent's "VictoryCondition" = $VictoryCondition_four;
	$NewThread( AIRootAgent's "VictoryCondition", #VictoryCondition_callback_frequency );	

	AIRootAgent's "Permanent_Hostility" = TRUE;
	AIRootAgent's "Deathmatch_Rules" = TRUE;
	/////////////////////////////////////////////////////////////////////////
	

	$SetPlayerTeamNumber ( EnemyPalace, $NewTeamNumber () );
	
	
	//Player 2 start. It will create its own thread
	$AddAttribute(AIRootAgent, "player2AI", "function", $enemy_player2_spawn);
	$RunThreadOnce ( AIRootAgent's "player2AI", ( 1000 ));

end



///////////////////////////////////////////////////////////////////////////////
function Dwarfeh_GetPlayerOnePalace () is agent
// Always return's player one's palace.
declare
	list palaces;
	agent palace, temp_palace;

begin
	Palaces = $ListPalaces ();
	//Get the Player 1 palace
	Foreach Temp_Palace in Palaces do
		begin
			If ( $GetUnitPlayerNumber ( Temp_Palace ) == #Player_1 )
		   	Palace = Temp_Palace;
		end
	return palace;
end

///////////////////////////////////////////////////////////////////////////////
function Dwarfeh_GetPlayerTwoPalace () is agent
// Always return's player two's palace.
declare
	list palaces, outposts;
	agent palace, temp_palace, outpost;

begin
	Palaces = $ListPalaces ();
	//Get the Player 2 palace
	
	//$debugout(911, "Dwarfeh AI: List of palaces:", palaces);
	
	Foreach Temp_Palace in Palaces do
		begin
			If ( $GetUnitPlayerNumber ( Temp_Palace ) == #Player_2 )
		   	Palace = Temp_Palace;
		end
	
	
	//$debugout(911, "Dwarfeh AI: Returning this for palace for player2", Palace);
	
	return palace;
	
end

//This is used only when it's a mod instead of a quest. It requires a building to be constructed
function playerOneAI( agent thisagent )
declare
	agent AIRootAgent, playerPalace;
	list guilds, guildsName, guildsTitle, current;
	integer members, max_members, gold, count;
	string buildingName, buildingTitle;
begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	
	//NOTE: Threads are entirely off of the function being ran. Therefore additional players means additional functions that perform the same task!
	
	//playerPalace = $gettruepalace ( thisagent );
	
	//AIRootAgent's "Deathmatch_Rules" = TRUE;
	
	playerPalace = $Dwarfeh_GetPlayerOnePalace ();
	
	$AdjustPlayerData ( playerPalace, "gold", 3000 );
	
	//Building variables for random builds
	$AddAttribute(playerPalace, "build_gnomes", "boolean", FALSE);
	$AddAttribute(playerPalace, "build_elves", "boolean", FALSE);
	$AddAttribute(playerPalace, "build_dwarves", "boolean", FALSE);
	$AddAttribute(playerPalace, "build_agrela", "boolean", FALSE);
	$AddAttribute(playerPalace, "build_krypta", "boolean", FALSE);
	$AddAttribute(playerPalace, "build_krolm", "boolean", FALSE);
	$AddAttribute(playerPalace, "build_helia", "boolean", FALSE);
	$AddAttribute(playerPalace, "build_lunord", "boolean", FALSE);
	$setRandomBuildVariables(playerPalace);	
	
	$AddAttribute(playerPalace, "playerAI_build", "function", $enemyPlayer2Build);
	$NewThread ( playerPalace's "playerAI_build", ( 1000 ), playerPalace);
	
	$AddAttribute(playerPalace, "playerAI_resurrect", "function", $AI_Check_Resurrect);
	$NewThread ( playerPalace's "playerAI_resurrect", ( 15000 ), playerPalace);

	$AddAttribute(playerPalace, "playerAI_guild_recruit", "function", $enemyPlayer2GuildSpawn);
	$NewThread ( playerPalace's "playerAI_guild_recruit", ( 30000 ), playerPalace);
	
	$AddAttribute(playerPalace, "playerAI_research", "function", $performEnemyPlayer2Research);
	$NewThread ( playerPalace's "playerAI_research", ( 60000 ), playerPalace);
	
	$AddAttribute(playerPalace, "playerAI_building_upgrade", "function", $performEnemyPlayer2BuildingUpgrade);
	$NewThread ( playerPalace's "playerAI_building_upgrade", ( 45000 ), playerPalace);
	
	$AddAttribute(playerPalace, "playerAI_flag_adder", "function", $AI_Post_Enemy_Reward);
	$NewThread ( playerPalace's "playerAI_flag_adder", ( 30000 ), playerPalace);
	
	$AddAttribute(playerPalace, "playerAI_flag_remover", "function", $AI_Flag_Remover);
	$NewThread ( playerPalace's "playerAI_flag_remover", ( 90000 ), playerPalace);

	$AddAttribute(playerPalace, "playerAI_cast_spells", "function", $Dwarfeh_AI_castSpells);
	$NewThread ( playerPalace's "playerAI_cast_spells", ( 30000 ), playerPalace);
	
	$AddAttribute(playerPalace, "flag_value", "integer", 0);
	$AddAttribute(playerPalace, "AI_Reward_Flags", "list");
	
	$basic_birth( thisagent );
	
end


function enemy_player2_spawn()
declare
	agent AIRootAgent, playerTwoPalace;
	list guilds, guildsName, guildsTitle, current;
	integer members, max_members, gold, count;
	string buildingName, buildingTitle;
begin
	
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	
	//NOTE: Threads are entirely off of the function being ran. Therefore additional players means additional functions that perform the same task!
	
	playerTwoPalace = $Dwarfeh_GetPlayerTwoPalace();
	
	//Building variables for random builds
	$AddAttribute(playerTwoPalace, "build_gnomes", "boolean", FALSE);
	$AddAttribute(playerTwoPalace, "build_elves", "boolean", FALSE);
	$AddAttribute(playerTwoPalace, "build_dwarves", "boolean", FALSE);
	$AddAttribute(playerTwoPalace, "build_agrela", "boolean", FALSE);
	$AddAttribute(playerTwoPalace, "build_krypta", "boolean", FALSE);
	$AddAttribute(playerTwoPalace, "build_krolm", "boolean", FALSE);
	$AddAttribute(playerTwoPalace, "build_helia", "boolean", FALSE);
	$AddAttribute(playerTwoPalace, "build_lunord", "boolean", FALSE);
	$setRandomBuildVariables(playerTwoPalace);	
	
	$AddAttribute(playerTwoPalace, "playerAI_build", "function", $enemyPlayer2Build);
	$NewThread ( playerTwoPalace's "playerAI_build", ( 1000 ), playerTwoPalace);
	
	$AddAttribute(playerTwoPalace, "playerAI_resurrect", "function", $AI_Check_Resurrect);
	$NewThread ( playerTwoPalace's "playerAI_resurrect", ( 15000 ), playerTwoPalace);

	$AddAttribute(playerTwoPalace, "playerAI_guild_recruit", "function", $enemyPlayer2GuildSpawn);
	$NewThread ( playerTwoPalace's "playerAI_guild_recruit", ( 30000 ), playerTwoPalace);
	
	$AddAttribute(playerTwoPalace, "playerAI_research", "function", $performEnemyPlayer2Research);
	$NewThread ( playerTwoPalace's "playerAI_research", ( 60000 ), playerTwoPalace);
	
	$AddAttribute(playerTwoPalace, "playerAI_building_upgrade", "function", $performEnemyPlayer2BuildingUpgrade);
	$NewThread ( playerTwoPalace's "playerAI_building_upgrade", ( 45000 ), playerTwoPalace);
	
	$AddAttribute(playerTwoPalace, "playerAI_flag_adder", "function", $AI_Post_Enemy_Reward);
	$NewThread ( playerTwoPalace's "playerAI_flag_adder", ( 30000 ), playerTwoPalace);
	
	$AddAttribute(playerTwoPalace, "playerAI_flag_remover", "function", $AI_Flag_Remover);
	$NewThread ( playerTwoPalace's "playerAI_flag_remover", ( 90000 ), playerTwoPalace);
	
	$AddAttribute(playerTwoPalace, "playerAI_cast_spells", "function", $Dwarfeh_AI_castSpells);
	$NewThread ( playerTwoPalace's "playerAI_cast_spells", ( 30000 ), playerTwoPalace);
	
	$AddAttribute(playerTwoPalace, "flag_value", "integer", 0);
	$AddAttribute(playerTwoPalace, "AI_Reward_Flags", "list");
	
	

	
end

///////////////////////////////////////////////////////////////////////////////
function enemyPlayer2GuildSpawn(agent palace)
declare
	agent guild, AIRootAgent, enemy_hero;
	list guilds, helia_guilds, new_helia_guilds;
	integer members, max_members, gold, count;
	string type;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	//$NewThread ( AIRootAgent's "SpecialSpawnScript", ( 30000 ));
	
	// build list of guilds.
	$ListObjects ( palace, "Building", -1, Guilds, #MyPlayer, #NoHiddenMap, #CheckSubtypes, "Guild" );

	foreach guild in guilds do // Generate a hero from each guild that needs one, if enough money is available.
		begin
			gold = $GetPlayerData ( palace, "gold" );
			//hack method of just generating heroes without caring. Most expensive unit is 1000 gold
			if ( gold >= 1000 && $getAttribute ( guild, #ATTRIB_FirstStageBuilt ) == 1 && guild's "title" != "Embassy") // Only spawn if you still have at least 1000 gold and the guild is actually built
				begin
					members = $ListSize ( guild's "members" );
					max_members = $getAttribute ( guild, #ATTRIB_MaxGuildMembers );
					if ( members < max_members ) // Only spawn if there is room in guild.
						begin
						
							if (guild's "title" == "Warriors_Guild")
								begin
									type = $Dwarfeh_AI_warriorGuildSpawn(palace);
								end
							else
								begin
									type = Guild's "Member_Title";							
								end

							enemy_hero = $SpawnUnit ( Guild, type, $LocationOf ( guild ));	
							
							$Generate_Character_Attributes ( enemy_hero ); 	// This is necessary for heroes that are not generated
																							// via an interface call.
																							
							//$debugout(911, "Dwarfeh AI: hero cost", type, enemy_hero's "cost");
							$AdjustPlayerData ( Guild, "gold", -enemy_hero's "cost" );																						
																							
							gold = $GetPlayerData ( palace, "gold" );
							$DebugOut ( 911, "AI Player #", $GetUnitPlayerNumber ( palace ), "Recruited", type, "for", enemy_hero's "cost"  ,"gold.", gold, "gold remaining." );
						end
				end
			else if ( gold >= 1000 && $getAttribute ( guild, #ATTRIB_FirstStageBuilt ) == 1 && guild's "title" == "Embassy")
				begin
					$Embassy_Spawn(guild);
				end
		end
end

function Dwarfeh_AI_warriorGuildSpawn(agent palace) is string
declare
	list		dauros_list, fervus_list;
	integer random;
	string type;
begin
		$ListObjects (palace, "building", -1, dauros_list, #MyPlayer, #ATTRIB_FirstStageBuilt, 1, #CheckTitles, "Temple_Dauros");
		$ListObjects (palace, "building", -1, fervus_list, #MyPlayer, #ATTRIB_FirstStageBuilt, 1, #CheckTitles, "Temple_Fervus");	
		if (palace's "build_agrela" && $ListSize ( dauros_list ) >= 1)
			begin						
				random = $RandomNumber(2) + 1;
				if (random == 1)
					begin
						type = "Warrior";
					end
				else if (random == 2)
					begin
						type = "Paladin";
				end			
			end
		else if (palace's "build_krypta" && $ListSize ( fervus_list ) >= 1)
			begin
				random = $RandomNumber(2) + 1;
				if (random == 1)
					begin
						type = "Warrior";
					end
				else if (random == 2)
					begin
						type = "Warrior_of_Discord";
				end					
			end
		else
			begin
				type = "Warrior";
			end
		
	return type;
end

function enemyPlayer2Build(agent palace)
declare
	agent guild, AIRootAgent, enemy_hero, spawnedBuilding;
	list guilds, guildsName, guildsTitle, current;
	integer random, members, max_members, gold, count;
	string buildingName, buildingTitle;
begin

	$randomPalaceBuild(palace);
	
	

end

function setRandomBuildVariables(agent palace)
declare
	list listGnomes, listElves, listDwarves, listAgrela, listDauros, listKrypta, listFervus, listKrolm, listLunord, listHelia;
	integer random;
	boolean hasGnomes, hasElves, hasDwarves, hasAgrela, hasDauros, hasKrypta, hasFervus, hasKrolm, hasLunord, hasHelia;
begin
	//Assume we have nothing
	hasGnomes = FALSE;
	hasElves = FALSE;
	hasDwarves = FALSE;
	hasAgrela = FALSE;
	hasDauros = FALSE;
	hasKrypta = FALSE;
	hasFervus = FALSE;
	hasKrolm = FALSE;
	hasLunord = FALSE;
	hasHelia = FALSE;

	//We may have been given buildings at the start of the game. We need to choose a faction and destroy others
	$ListObjects ( palace, "building", -1, listGnomes, #MyPlayer, #CheckTitles, "Gnome_Hovel" );
	$ListObjects ( palace, "building", -1, listElves, #MyPlayer, #CheckTitles, "Elven_Bungalow" );
	$ListObjects ( palace, "building", -1, listDwarves, #MyPlayer, #CheckTitles, "Dwarven_Settlement" );
	
	$ListObjects ( palace, "building", -1, listAgrela, #MyPlayer, #CheckTitles, "Temple_Agrela" );
	$ListObjects ( palace, "building", -1, listDauros, #MyPlayer, #CheckTitles, "Temple_Dauros" );
	$ListObjects ( palace, "building", -1, listKrypta, #MyPlayer, #CheckTitles, "Temple_Krypta" );
	$ListObjects ( palace, "building", -1, listFervus, #MyPlayer, #CheckTitles, "Temple_Fervus" );
	$ListObjects ( palace, "building", -1, listKrolm, #MyPlayer, #CheckTitles, "Temple_Krolm" );
	
	$ListObjects ( palace, "building", -1, listLunord, #MyPlayer, #CheckTitles, "Temple_Lunord" );
	$ListObjects ( palace, "building", -1, listHelia, #MyPlayer, #CheckTitles, "Temple_Helia" );
	
	
	
	if ($ListSize ( listGnomes ) >= 1)
		hasGnomes = TRUE;
	if ($ListSize ( listElves ) >= 1)
		hasElves = TRUE;
	if ($ListSize ( listDwarves ) >= 1)
		hasDwarves = TRUE;
	
	//Started with 1 of the factions
	if (hasGnomes && hasElves == FALSE && hasDwarves == FALSE)
		begin
			palace's "build_gnomes" = TRUE;
		end
	if (hasGnomes == FALSE && hasElves && hasDwarves == FALSE)
		begin
			palace's "build_elves" = TRUE;
		end
	if (hasGnomes == FALSE && hasElves == FALSE && hasDwarves)
		begin
			palace's "build_dwarves" = TRUE;
		end

	//Started with 2 of the factions. Need to choose 1
	if (hasGnomes && hasElves && hasDwarves == FALSE)
		begin
			random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-3
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Chose gnomes", palace);
					palace's "build_gnomes" = TRUE;
					$destroyBuildingsInList(listElves);
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Chose elves", palace);
					palace's "build_elves" = TRUE;
					$destroyBuildingsInList(listGnomes);
				end	
		end
	if (hasGnomes == FALSE && hasElves && hasDwarves)
		begin
			random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-2
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Chose elves", palace);
					palace's "build_elves" = TRUE;
					$destroyBuildingsInList(listDwarves);
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Chose dwarves", palace);
					palace's "build_dwarves" = TRUE;
					$destroyBuildingsInList(listElves);
				end	
		end
	if (hasGnomes && hasElves == FALSE && hasDwarves)
		begin
			random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-3
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Chose gnomes", palace);
					palace's "build_gnomes" = TRUE;
					$destroyBuildingsInList(listDwarves);
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Chose dwarves", palace);
					palace's "build_dwarves" = TRUE;
					$destroyBuildingsInList(listGnomes);
				end	
		end	
	
	//Started with 3 of the factions. Need to choose 1
	if ( (hasGnomes && hasElves && hasDwarves))
		begin
			random = $RandomNumber ( 3 ) + 1; // Randomly choose number 1-3
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Chose gnomes", palace);
					palace's "build_gnomes" = TRUE;
					$destroyBuildingsInList(listElves);
					$destroyBuildingsInList(listDwarves);
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Chose elves", palace);
					palace's "build_elves" = TRUE;
					$destroyBuildingsInList(listGnomes);
					$destroyBuildingsInList(listDwarves);					
				end
			else if ( random == 3)
				begin
					$debugout(911, "Dwarfeh AI: Chose dwarves", palace);
					palace's "build_dwarves" = TRUE;
					$destroyBuildingsInList(listGnomes);
					$destroyBuildingsInList(listElves);	
				end	
		end	

	if ($ListSize ( listAgrela ) >= 1 || $ListSize ( listDauros ) >= 1)
		hasAgrela = TRUE;
	if ($ListSize ( listKrypta ) >= 1 || $ListSize ( listFervus ) >= 1)
		hasKrypta = TRUE;
	if ($ListSize ( listKrolm ) >= 1)
		hasKrolm = TRUE;
		
	//Started with 1 of the factions
	if (hasAgrela && hasKrypta == FALSE && hasKrolm == FALSE)
		begin
			$debugout(911, "Dwarfeh AI: Started with Agrela/Dauros", palace);
			palace's "build_agrela" = TRUE;
		end
	if (hasAgrela == FALSE && hasKrypta && hasKrolm == FALSE)
		begin
			$debugout(911, "Dwarfeh AI: Started with Krypta/Fervus", palace);
			palace's "build_krypta" = TRUE;
		end
	if (hasAgrela == FALSE && hasKrypta == FALSE && hasKrolm)
		begin
			$debugout(911, "Dwarfeh AI: Started with Krolm");
			palace's "build_krolm" = TRUE;
		end
		
	//Started with 2 of the factions. Need to choose 1
	if (hasAgrela && hasKrypta && hasKrolm == FALSE)
		begin
			random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-3
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Chose Agrela");
					palace's "build_agrela" = TRUE;
					$destroyBuildingsInList(listKrypta);
					$destroyBuildingsInList(listFervus);
					$destroyBuildingsInList(listKrolm);
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Chose Krypta");
					palace's "build_krypta" = TRUE;
					$destroyBuildingsInList(listAgrela);
					$destroyBuildingsInList(listDauros);
					$destroyBuildingsInList(listKrolm);
				end	
		end
	if (hasAgrela == FALSE && hasKrypta && hasKrolm)
		begin
			random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-2
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Chose Krypta");
					palace's "build_krypta" = TRUE;
					$destroyBuildingsInList(listAgrela);
					$destroyBuildingsInList(listDauros);
					$destroyBuildingsInList(listKrolm);
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Chose Krolm over other temples");
					palace's "build_krolm" = TRUE;
					$destroyBuildingsInList(listKrypta);
					$destroyBuildingsInList(listFervus);
					$destroyBuildingsInList(listAgrela);
					$destroyBuildingsInList(listDauros);
					$destroyBuildingsInList(listLunord);
					$destroyBuildingsInList(listHelia);
				end	
		end
	if (hasAgrela && hasKrypta == FALSE && hasKrolm)
		begin
			random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-3
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Chose Agrela");
					palace's "build_agrela" = TRUE;
					$destroyBuildingsInList(listKrypta);
					$destroyBuildingsInList(listFervus);
					$destroyBuildingsInList(listKrolm);
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Chose Krolm over other temples");
					palace's "build_krolm" = TRUE;
					$destroyBuildingsInList(listKrypta);
					$destroyBuildingsInList(listFervus);
					$destroyBuildingsInList(listAgrela);
					$destroyBuildingsInList(listDauros);
					$destroyBuildingsInList(listLunord);
					$destroyBuildingsInList(listHelia);
				end	
		end	

	//Started with 3 of the factions. Need to choose 1
	if ( (hasAgrela && hasKrypta && hasKrolm))
		begin
			random = $RandomNumber ( 3 ) + 1; // Randomly choose number 1-3
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Chose Agrela");
					palace's "build_agrela" = TRUE;
					$destroyBuildingsInList(listKrypta);
					$destroyBuildingsInList(listFervus);
					$destroyBuildingsInList(listKrolm);
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Chose Krypta");
					palace's "build_krypta" = TRUE;
					$destroyBuildingsInList(listAgrela);
					$destroyBuildingsInList(listDauros);
					$destroyBuildingsInList(listKrolm);				
				end
			else if ( random == 3)
				begin
					$debugout(911, "Dwarfeh AI: Chose Krolm over other temples");
					palace's "build_krolm" = TRUE;
					$destroyBuildingsInList(listKrypta);
					$destroyBuildingsInList(listFervus);
					$destroyBuildingsInList(listAgrela);
					$destroyBuildingsInList(listDauros);
					$destroyBuildingsInList(listLunord);
					$destroyBuildingsInList(listHelia);
				end	
		end	

	if ($ListSize ( listLunord ) >= 1)
		hasLunord = TRUE;
	if ($ListSize ( listHelia ) >= 1)
		hasHelia = TRUE;
	
	//Started with 1 of the factions
	if (hasLunord && hasHelia == FALSE && palace's "build_krolm" == FALSE)
		begin
			$debugout(911, "Dwarfeh AI: Started with Helia");
			palace's "build_lunord" = TRUE;
		end
	if (hasLunord == FALSE && hasHelia && palace's "build_krolm" == FALSE)
		begin
			$debugout(911, "Dwarfeh AI: Started with Lunord");
			palace's "build_helia" = TRUE;
		end
		
	//Started with both of the factions. Need to choose 1
	if (hasLunord && hasHelia && palace's "build_Krolm" == FALSE)
		begin
			random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-3
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Chose Lunord over Helia");
					palace's "build_lunord" = TRUE;
					$destroyBuildingsInList(listHelia);
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Chose Helia over Lunord");
					palace's "build_helia" = TRUE;
					$destroyBuildingsInList(listLunord);
				end	
		end		

	//Gnomes can only be built if palace is level 1
	if (hasGnomes == FALSE && hasElves == FALSE && hasDwarves == FALSE)
		begin
			if ( palace's "level" == 1 )
				begin
					random = $RandomNumber ( 3 ) + 1; // Randomly choose number 1-3
					if ( random == 1 )
						begin
							$debugout(911, "Dwarfeh AI: Random Build choice (palace level 1): gnomes");
							palace's "build_gnomes" = TRUE;
						end
					else if ( random == 2)
						begin
							$debugout(911, "Dwarfeh AI: Random Build choice (palace level 1): elves");
							palace's "build_elves" = TRUE;
						end
					else if ( random == 3)
						begin
							$debugout(911, "Dwarfeh AI: Random Build choice (palace level 1): dwarves");
							palace's "build_dwarves" = TRUE;
						end				
				end	
			else
				begin
					random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-2
					if ( random == 1 )
						begin
							$debugout(911, "Dwarfeh AI: Random Build choice (palace level 2 or higher): elves");
							palace's "build_elves" = TRUE;
						end
					else if ( random == 2)
						begin
							$debugout(911, "Dwarfeh AI: Random Build choice (palace level 2 or higher): dwarves");
							palace's "build_dwarves" = TRUE;
						end			
				end
		end
	
	if (hasAgrela == FALSE && hasKrypta == FALSE && hasKrolm == FALSE)
		begin
			//We can only randomly choose krolm if we also don't have lunord and helia
			if (hasLunord == FALSE && hasHelia == FALSE)
				begin
					random = $RandomNumber ( 3 ) + 1; // Randomly choose number 1-3
				end
			else
				begin
					random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-2
				end
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Random Build choice: agrela");
					palace's "build_agrela" = TRUE;
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Random Build choice: krypta");
					palace's "build_krypta" = TRUE;
				end
			else if ( random == 3)
				begin
					$debugout(911, "Dwarfeh AI: Random Build choice: krolm");
					palace's "build_krolm" = TRUE;
				end
		end

	if (palace's "build_krolm" == FALSE && hasLunord == FALSE && hasHelia == FALSE)
		begin
			random = $RandomNumber ( 2 ) + 1; // Randomly choose number 1-2
			if ( random == 1 )
				begin
					$debugout(911, "Dwarfeh AI: Random Build choice: helia");
					palace's "build_helia" = TRUE;
				end
			else if ( random == 2)
				begin
					$debugout(911, "Dwarfeh AI: Random Build choice: lunord");
					palace's "build_lunord" = TRUE;
				end
		end
	
end

function destroyBuildingsInList(list buildings)
declare
	agent building;
begin
	foreach building in buildings do
		begin
			$building_death(building);
		end
	
end

function randomPalaceBuild(agent palace)
declare
	agent guild, AIRootAgent, enemy_hero, spawnedBuilding, tempMarket, tempFairGrounds;
	list guilds, guildsName, guildsTitle, current, tempMarketList, tempMagicBazaarList, tempFairGroundsList;
	integer members, max_members, gold, count, totalHeroCount;
	string buildingName, buildingTitle;
begin

	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	totalHeroCount = $getTotalHeroLevel(palace);
	
	$NewThread ( palace's "playerAI_build", ( 30000 ));
	
	
	buildingName = "Gnome_Hovel";
	buildingTitle = buildingName;
	$ListObjects ( palace, "building", -1, guilds, #MyPlayer );
	current = $RemoveTitles ( guilds, buildingTitle );
	count = $ListSize ( current );
	
	if ( count < 1 && palace's "level" == 1 && palace's "build_gnomes" == TRUE)
		begin			
			if ($canAffordBuilding( buildingName, buildingTitle, palace ))
				begin
					$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
					spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
				end
		end	

	buildingName = "GuardHouse1";
	buildingTitle = "GuardHouse";	
	current = $RemoveTitles ( guilds, buildingTitle );
	count = $ListSize ( current );		
	
	//TODO: Rewrite this to assign a specific attribute to the marketplace guardhouse with agent id
	//If agentid doesn't exist make another one for a marketplace guardhouse
	//This was old way of ensuring marketplace was protected by guardhouse. Now trading posts are protected too!
	if ( count < 1 )
		begin
			if ($canAffordBuilding( buildingName, buildingTitle, palace ))
				begin
					$ListObjects ( palace, "building", -1, tempMarketList, #MyPlayer, #CheckTitles, "Marketplace" );
					if ($ListSize (tempMarketList) >= 1)
						begin		
							tempMarket = $listmember ( tempMarketList, 1 );
							$buildGuardhouse(palace, tempMarket);
						end
				end
		end

	buildingName = "Marketplace1";
	buildingTitle = "Marketplace";
	current = $RemoveTitles ( guilds, buildingTitle );
	count = $ListSize ( current );
	
	if ( count < 1 )
		begin
			if ($canAffordBuilding( buildingName, buildingTitle, palace ))
				begin
					$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
					spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
					$buildGuardhouse(palace, spawnedBuilding);
				end
		end


		
	
	buildingName = "Rangers_Guild";
	buildingTitle = buildingName;
	current = $RemoveTitles ( guilds, buildingTitle );
	count = $ListSize ( current );
	
	if ( count < 2 )
		begin
			if ($canAffordBuilding( buildingName, buildingTitle, palace ))
				begin
					$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
					spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
				end
		end
		
	buildingName = "Rogues_Guild1";
	buildingTitle = "Rogues_Guild";
	current = $RemoveTitles ( guilds, buildingTitle );
	count = $ListSize ( current );
	
	if ( count < 1 )
		begin
			if ($canAffordBuilding( buildingName, buildingTitle, palace ))
				begin
					$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
					spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
				end
		end
		
	buildingName = "Blacksmith1";
	buildingTitle = "Blacksmith";
	current = $RemoveTitles ( guilds, buildingTitle );
	count = $ListSize ( current );
	
	if ( count < 1 )
		begin
			if ($canAffordBuilding( buildingName, buildingTitle, palace ))
				begin
					$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
					spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );					
				end
		end
		
	buildingName = "Trading_Post";
	buildingTitle = "Trading_Post";
	current = $RemoveTitles ( guilds, buildingTitle );
	count = $ListSize ( current );
	
	if ( count < 3 )
		begin
			if ($canAffordBuilding( buildingName, buildingTitle, palace ))
				begin
					//gold adjustment is handled in the method itself
					$buildTradingPost(palace, buildingName, buildingTitle);
				end
		end
	else if ( (count == 3 && totalHeroCount >= 100) || (count == 4 && totalHeroCount >= 200) || (count == 5 && totalHeroCount >= 300) || (count == 6 && totalHeroCount >= 400) )
		begin
			if ($canAffordBuilding( buildingName, buildingTitle, palace ))
				begin
					//gold adjustment is handled in the method itself
					$buildTradingPost(palace, buildingName, buildingTitle);
				end
		end
	
	if ( palace's "level" == 2 && $getAttribute ( palace, #ATTRIB_currentstagebuilt ) == 1)
		begin
		
		
			//We only want to expand if we have more than 5000 gold because we want to afford heroes/basic buildings/upgrades
			
			if ($GetPlayerData ( palace, "gold" ) >= 5000)
				begin
			
					buildingName = "Inn";
					buildingTitle = buildingName;
					current = $RemoveTitles ( guilds, buildingTitle );
					count = $ListSize ( current );
					
					if ( palace's "build_elves" && count < 1)
						begin
							if ($canAffordBuilding( buildingName, buildingTitle, palace ))
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );				
								end
						end

					buildingName = "Elven_Bungalow";
					buildingTitle = buildingName;
					current = $RemoveTitles ( guilds, buildingTitle );
					count = $ListSize ( current );
			
					if (palace's "build_elves" && count < 2)
						begin
							if ($canBuild(palace, "Elven_Bungalow", "Elven_Bungalow") && $canAffordBuilding( buildingName, buildingTitle, palace ))
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );	
								end
						end

					buildingName = "Dwarven_Settlement";
					buildingTitle = buildingName;
					current = $RemoveTitles ( guilds, buildingTitle );
					count = $ListSize ( current );
							
					if (palace's "build_dwarves" && count < 1)
						begin
							if ($canBuild(palace, "Dwarven_Settlement", "Dwarven_Settlement") && $canAffordBuilding( buildingName, buildingTitle, palace ))
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );	
								end
						end			

					buildingName = "Ballista_Tower";
					buildingTitle = buildingName;
					current = $RemoveTitles ( guilds, buildingTitle );
					count = $ListSize ( current );

					if (palace's "build_dwarves" && count < 1)
						begin
							if ($canBuild(palace, "Ballista_Tower", "Ballista_Tower") && $canAffordBuilding( buildingName, buildingTitle, palace ))
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );	
								end
						end		
			
					buildingName = "Temple_Agrela1";
					buildingTitle = "Temple_Agrela";
					current = $RemoveTitles ( guilds, buildingTitle );
					count = $ListSize ( current );

					if (palace's "build_agrela" && count < 1)
						begin
							if ($canAffordBuilding( buildingName, buildingTitle, palace ))
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );				
								end
						end

					buildingName = "Temple_Krypta1";
					buildingTitle = "Temple_Krypta";
					current = $RemoveTitles ( guilds, buildingTitle );
					count = $ListSize ( current );			
					
					if (palace's "build_krypta" && count < 1)
						begin
							if ($canAffordBuilding( buildingName, buildingTitle, palace ))
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );				
								end
						end					

					buildingName = "Temple_Dauros1";
					buildingTitle = "Temple_Dauros";
					current = $RemoveTitles ( guilds, buildingTitle );
					count = $ListSize ( current );
					
					if (palace's "build_agrela" && count < 1)
						begin
							if ($canAffordBuilding( buildingName, buildingTitle, palace ))
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );				
								end
						end
					
					buildingName = "Temple_Fervus1";
					buildingTitle = "Temple_Fervus";
					current = $RemoveTitles ( guilds, buildingTitle );
					count = $ListSize ( current );
					
					if (palace's "build_krypta" && count < 1)
						begin
							if ($canAffordBuilding( buildingName, buildingTitle, palace ))
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );				
								end
						end	

			end
	
		end		
	
	//Looks like we made it to an important stepping stone lets expand more
	if ( (palace's "level" == 3 && $getAttribute ( palace, #ATTRIB_currentstagebuilt ) == 1) || palace's "subtype" == "Outpost")
		begin
	
			buildingName = "Elven_Bungalow";
			buildingTitle = buildingName;
			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );
		
			if (palace's "build_elves" && count < 2)
				begin
					if ($canBuild(palace, "Elven_Bungalow", "Elven_Bungalow") && $canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
							spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );	
						end
				end
		
			buildingName = "Dwarven_Settlement";
			buildingTitle = buildingName;
			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );
					
			if (palace's "build_dwarves" && count < 1)
				begin
					if ($canBuild(palace, "Dwarven_Settlement", "Dwarven_Settlement") && $canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
							spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );	
						end
				end		

			buildingName = "SorcerersAbode";
			buildingTitle = "SorcerersAbode";	
			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );		
			
			if ( count < 1 )
				begin
					if ($canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							$ListObjects ( palace, "building", -1, tempMagicBazaarList, #MyPlayer, #CheckTitles, "Magic_Bazaar" );
							$ListObjects ( palace, "building", -1, tempFairGroundsList, #MyPlayer, #CheckTitles, "Fairgrounds" );
							if ($ListSize (tempMagicBazaarList) >= 1 && $ListSize(tempFairGroundsList) >= 1)
								begin
									tempFairGrounds = $listmember ( tempFairGroundsList, 1 );
									$buildSorcerersAbode(palace, tempFairGrounds);
								end
						end
				end		
		
			buildingName = "Fairgrounds";
			buildingTitle = buildingName;
			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );
			
			if ( count < 1 && totalHeroCount >= 20 )
				begin
					if ($canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							gold = $getBuildingCost( buildingName, buildingTitle, palace );
							//$debugout(911, "Dwarfeh AI: Getting price for fairgrounds right before purchase", gold);
							$AdjustPlayerData ( palace, "gold", -gold );
							spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );							
						end
				end		
			
			if (palace's "build_helia" == TRUE)
				begin
					buildingName = "Temple_Helia1";
					buildingTitle = "Temple_Helia";
				end
			else if (palace's "build_lunord" == TRUE)
				begin
					buildingName = "Temple_Lunord1";
					buildingTitle = "Temple_Lunord";
				end			
			else if (palace's "build_krolm" == TRUE)
				begin
					buildingName = "Temple_Krolm";
					buildingTitle = "Temple_Krolm";
				end				

			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );
			
			if ( count < 2 )
				begin
					if ($canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
							spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
						end
				end
				
			buildingName = "MagicBazaar";
			buildingTitle = "Magic_Bazaar";
			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );
			
			if ( count < 1 )
				begin
					if ($canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
							spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
						end
				end
				
			buildingName = "Library1";
			buildingTitle = "Library";
			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );
			
			if ( count < 1 )
				begin
					if ($canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							//Costs are handled in the method
							$buildLibrary( palace, buildingName, buildingTitle );					
						end
				end	
				
			buildingName = "Statue";
			buildingTitle = buildingName;
			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );
			
			if ( count < 4 && totalHeroCount >= 100 )
				begin
					if ($canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
							spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );				
						end
				end
				
			buildingName = "Royal_gardens";
			buildingTitle = buildingName;
			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );
			
			if ( count < 3 && totalHeroCount >= 200 )
				begin
					if ($canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
							spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );				
						end
				end	
				
			buildingName = "Inn";
			buildingTitle = buildingName;
			current = $RemoveTitles ( guilds, buildingTitle );
			count = $ListSize ( current );
			
			if ( (count < 4 && totalHeroCount >= 100) || (count < 1 && palace's "build_elves") )
				begin
					if ($canAffordBuilding( buildingName, buildingTitle, palace ))
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
							spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );				
						end
				end	
			
			//Lets build a build order that focuses more on strength for auto expanding
			if (palace's "build_helia" == TRUE)
				begin
					guildsName << "Temple_Helia1";
					guildsTitle << "Temple_Helia";
				end
			else if (palace's "build_lunord" == TRUE)
				begin
					guildsName << "Temple_Lunord1";
					guildsTitle << "Temple_Lunord";
				end			
			else if (palace's "build_krolm" == TRUE)
				begin
					guildsName << "Temple_Krolm";
					guildsTitle << "Temple_Krolm";
				end				
			//One of the above will always be true, so we need to turn it into an array now
			
			guildsName = $AddLists(guildsName, $Concatenate( "Outpost", "Wizards_Guild1"));
			guildsTitle = $AddLists(guildsTitle, $Concatenate( "Outpost", "Wizards_Guild"));

			if (palace's "build_elves" == TRUE)
				begin
					if ($canBuild(palace, "Elven_Bungalow", "Elven_Bungalow"))
						begin
							guildsName << "Elven_Bungalow";
							guildsTitle << "Elven_Bungalow";
						end
				end
			else if (palace's "build_dwarves" == TRUE)
				begin
					if ($canBuild(palace, "Dwarven_Settlement", "Dwarven_Settlement"))
						begin
							guildsName << "Dwarven_Settlement";
							guildsTitle << "Dwarven_Settlement";
						end
					if ($canBuild(palace, "Ballista_Tower", "Ballista_Tower"))
						begin
							guildsName << "Ballista_Tower";
							guildsTitle << "Ballista_Tower";
						end
				end				
			
			if (palace's "build_agrela" == TRUE)
				begin
					guildsName << "Temple_Agrela1";
					guildsTitle << "Temple_Agrela";
				end
			else if (palace's "build_krypta" == TRUE)
				begin
					guildsName << "Temple_Krypta1";
					guildsTitle << "Temple_Krypta";
				end					
			
			guildsName = $AddLists(guildsName, $Concatenate("Warriors_Guild", "Rangers_Guild", "Rogues_Guild1", "Embassy"));
			guildsTitle = $AddLists(guildsTitle, $Concatenate( "Warriors_Guild", "Rangers_Guild", "Rogues_Guild", "Embassy"));
			
			if (palace's "build_agrela" == TRUE)
				begin
					guildsName << "Temple_Dauros1";
					guildsTitle << "Temple_Dauros";
				end
			else if (palace's "build_krypta" == TRUE)
				begin
					guildsName << "Temple_Fervus1";
					guildsTitle << "Temple_Fervus";
				end	
		
			//Arrays start at 1 in GPL code, so we start this at 1.
			count = 1;
			//Start with a brand new building list for auto expanding. Maybe better to go to a brand new thread instead?
			$ListObjects ( palace, "Building", -1, guilds, #MyPlayer);
			
			foreach buildingName in guildsName do
				begin
					buildingTitle = $ListMember(guildsTitle, count);										
					
					current = $RemoveTitles ( guilds, buildingTitle );
	
					//$debugout(911, "Dwarfeh AI: pre canAffordBuilding");
					//$debugout(911, "Dwarfeh AI: canAffordBuilding", $canAffordBuilding( buildingName, buildingTitle, palace ));
					//$debugout(911, "Dwarfeh AI: count:", count, "buildingName", buildingName, "buildingTitle", buildingTitle, "Guilds found with title:", current, "Guilds found without title:", guilds);
					//$debugout(911, "Dwarfeh AI: pre ListSize");
					//$debugout(911, "Dwarfeh AI: ListSize", $ListSize ( current ));

					//We want to require 10k gold to auto expand beyond the first building so the AI has gold to upgrade/revive stuff early
					if ($ListSize ( current ) == 0 && $GetPlayerData ( palace, "gold" ) >= 5000 && totalHeroCount >= 20)
						begin
							if ($canAffordBuilding( buildingName, buildingTitle, palace ) && (buildingName != "Embassy" && buildingName != "Outpost"))
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
								end
							else if ($canAffordBuilding( buildingName, buildingTitle, palace ) && buildingName == "Outpost" && totalHeroCount >= 100)
								begin
									//Costs are handled directly in method
									$buildOutpost( palace, buildingName, buildingTitle);
								end
							else if ($canAffordBuilding( buildingName, buildingTitle, palace ) && buildingName == "Embassy" && totalHeroCount >= 100)
								begin
									$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
								end
						end
					else
						begin
							if ($canAffordBuilding( buildingName, buildingTitle, palace ) && $GetPlayerData ( palace, "gold" ) >= 10000 && totalHeroCount >= 20)
								begin
									if (buildingName != "Outpost")
										begin
											//$debugout(911, "Dwarfeh AI: cost for above building: ", $getBuildingCost( buildingName, buildingTitle, palace ), "canAffordBuilding:", $canAffordBuilding( buildingName, buildingTitle, palace ));
											$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
											spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
										end
									else if (buildingName == "Outpost" && totalHeroCount >= 100)
										begin
											//Costs are handled directly in method
											$buildOutpost( palace, buildingName, buildingTitle);										
										end
									else if (buildingName == "Embassy" && totalHeroCount >= 100)
										begin
											$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
											spawnedBuilding = $SpawnUnit (palace , buildingName , "clear" );
										end
								end							
							
						end
					
					count += 1;				
				end
		end
end

//Puts a guardhouse as close to possible to a building. 
function buildGuardhouse(agent palace, agent building)
declare
	string buildingName, buildingTitle;
begin
	buildingName = "GuardHouse1";
	buildingTitle = "GuardHouse";
	if ($canAffordBuilding( buildingName, buildingTitle, palace ))
		begin
			$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
			$SpawnUnit (building , buildingName , "clear" );
		end

end

function buildSorcerersAbode(agent palace, agent fairgrounds)
declare
	string buildingName, buildingTitle;
begin
	buildingName = "SorcerersAbode";
	buildingTitle = "SorcerersAbode";
	if ($canAffordBuilding( buildingName, buildingTitle, palace ))
		begin
			$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
			$SpawnUnit (fairgrounds , buildingName , "clear" );
		end

end

//Check for cost is handled beforehand
function buildLibrary(agent palace, string buildingName, string buildingTitle)
declare
	list buildings;
	agent building;
begin
	$ListObjects ( palace, "building", -1, buildings, #MyPlayer, #CheckTitles, "Wizards_Guild", #ATTRIB_FirstStageBuilt, 1 );
	
	//This means a wizard's guild is already fully built
	if ($ListSize ( buildings) >= 1)
		begin
			$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ));
			$SpawnUnit (palace , "Library1" , "clear" );
		end

end

function getTotalHeroLevel(agent palace) is integer
declare
	list heroes;
	integer total_level;
	agent hero;
begin
	total_level = 0;
	$ListObjects ( palace, "hero", -1, heroes, #CheckSubtypes, "hero", #MyPlayer, #InsideOtherUnits );

	foreach hero in heroes do // Add up the total level of your heroes.
		begin
			total_level += $GetAttribute ( hero, #ATTRIB_ExperienceLevel );
		end
	
	return total_level;
end

function canBuild(agent palace, string buildingName, string buildingTitle) is boolean
declare
	list buildingList;
	agent building;
	integer buildingCount;
	boolean hasRequirements, hasMarket, hasInn;
	
begin
	hasRequirements = FALSE;
	if (buildingName == "Dwarven_Settlement")
		begin
			$ListObjects ( palace, "Building", -1, buildingList, #MyPlayer, #CheckTitles, "Blacksmith" );
			
			buildingCount = $ListSize ( buildingList );
			//$debugout(911, "Dwarfeh AI: Current list of blacksmiths", buildingList, "count:", buildingCount);
			
			foreach building in buildingList do
				begin
					//$debugout(911, "Dwarfeh AI: #ATTRIB_FirstStageBuilt", $getAttribute ( building, #ATTRIB_FirstStageBuilt ), "building level:", building's "level");
					if ($getAttribute ( building, #ATTRIB_FirstStageBuilt ) == 1 && building's "level" == 3 && palace's "level" >= 2)
						begin
							//$debugout(911, "Dwarfeh AI: Returning true for blacksmith being built");
							hasRequirements = TRUE;
							
						end
				end
		end
	else if (buildingName == "Ballista_Tower")
		begin
			$ListObjects ( palace, "Building", -1, buildingList, #MyPlayer, #CheckTitles, "Dwarven_Settlement", #ATTRIB_FirstStageBuilt, 1 );
			buildingCount = $ListSize ( buildingList );
			
			if (buildingCount >= 1)
				begin
					hasRequirements = TRUE;
				end
			
		end
	else if (buildingName == "Elven_Bungalow")
		begin
			$ListObjects ( palace, "Building", -1, buildingList, #MyPlayer, #CheckTitles, "Inn", #ATTRIB_FirstStageBuilt, 1 );
			buildingCount = $ListSize ( buildingList );
			//$debugout(911, "Dwarfeh AI: Current list of Inns", buildingList, "count:", buildingCount);
			
			if (buildingCount >= 1)
				begin
					hasInn = TRUE;
				end		
			
			$ListObjects ( palace, "Building", -1, buildingList, #MyPlayer, #CheckTitles, "Marketplace", #ATTRIB_FirstStageBuilt, 1 );
			buildingCount = $ListSize ( buildingList );
			//$debugout(911, "Dwarfeh AI: Current list of marketplaces", buildingList, "count:", buildingCount);
			
			if (buildingCount >= 1)
				begin
					hasMarket = TRUE;
				end

			if (hasInn && hasMarket && palace's "level" >= 2)
				begin
					hasRequirements = TRUE;
				end
			
			
		end 

	return hasRequirements;
end



function buildOutpost(agent palace, string BuildingName, string buildingTitle)
declare
	list outpostList;
	integer distance, boardX, boardY;
	coordinate boardSize, outpostLocation;
	boolean canBuildOutpost;
	agent building;
begin
	boardSize = $getBoardExtents();
	boardX = $getX ( boardSize );
	boardY = $getY ( boardSize );

	outpostLocation = $randomCoord( palace , #Min_Dist_To_Palace_for_Outpost, 2000);
	//There is no check to SpawnUnit. If you spawn the unit off the map the game crashes. This should never happen in this scenario but I've had weird bugs
	if ($getX(outpostLocation) < boardX && $getY(outpostLocation) < boardY)
		begin
			//The coordinate is spawned a minimum distance from palace above so no need to check distance to palace
			$ListObjects ( palace, "building", -1, outpostList, #MyPlayer, #CheckTitles, "Outpost" );
			
			canBuildOutpost = TRUE;
			
			foreach building in outpostList do
				begin
					if ($DistanceBetweenCoords($LocationOf( building ), outpostLocation) < #Min_Dist_To_Palace_for_Outpost)
						begin
							//$debugout(911, "Dwarfeh AI: Random coordinate for building outpost failed. Distance between coords:", $DistanceBetweenCoords($LocationOf( building ), outpostLocation), "Building coord:", $LocationOf( building ), "Outpost coord:", outpostLocation);
							canBuildOutpost = FALSE;
						end
				end			
			
			if (canBuildOutpost)
				begin
					$constructBuilding( palace, buildingName, buildingTitle, outpostLocation);
					//$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
					//$SpawnUnit (palace , "Outpost" , outpostLocation, "clear" );				
				end
					
		end
	else
		begin
			$debugout(911, "Dwarfeh AI: Failed to generate outpost within map coordinates");
		end
end

//Check for cost is handled beforehand
function buildTradingPost(agent palace, string BuildingName, string buildingTitle)
declare
	list marketplaceList, tradingPostList, closedMarketplaceList, combinedList;
	integer distance, boardX, boardY;
	coordinate boardSize, tradingPostLocation;
	boolean canBuildTradingPost;
	agent AIRootAgent, building;
begin

	boardSize = $getBoardExtents();
	boardX = $getX ( boardSize );
	boardY = $getY ( boardSize );

	//original values is 2800, 3400 search. However, I tied it to variable case so the AI distance is also updated
	
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	if (AIRootAgent's "Deathmatch_Rules")
		begin
			if ( boardX > 5000 )
				distance = #Deathmatch_Large_Trade_Radius;
			else
				distance = #Deathmatch_Small_Trade_Radius;
			tradingPostLocation = $RandomCoord( palace , distance, (distance + 600));
		end
	else
		begin
			distance = #Min_Dist_to_Market_For_Caravan_Spawn;
			tradingPostLocation = $RandomCoord( palace , #Min_Dist_to_Market_For_Caravan_Spawn, (#Min_Dist_to_Market_For_Caravan_Spawn + 2400));
		end
	
	
	//$debugout(911, "Dwarfeh AI: Random coordinate generated for trading post:", tradingPostLocation);
	
	//There is no check to SpawnUnit. If you spawn the unit off the map the game crashes. This should never happen in this scenario but I've had weird bugs
	if ($getX(tradingPostLocation) < boardX && $getY(tradingPostLocation) < boardY)
		begin
			//Lets perform all the human checks which is getting all marketplaces & trading posts within distance
			$ListObjects ( palace, "building", -1, marketplaceList, #MyPlayer );
			closedMarketplaceList = $ListTitles ( marketplaceList, "closed" );
			marketplaceList = $ListTitles ( marketplaceList, "marketplace" );

			marketplaceList = $addLists ( marketplaceList, closedMarketplaceList );
			
			//Trading Posts require a marketplace to exist before building one at all
			if ($ListSize ( marketplaceList) > 0)
				begin
					canBuildTradingPost = TRUE;
					
					foreach building in marketplaceList do
						begin
							//check to see if the market level 1 has been fully built which is a requirement for trading post
							if ($getAttribute ( building, #ATTRIB_FirstStageBuilt ) == 0)
								begin
									canBuildTradingPost = FALSE;
								end
						end
								
					$ListObjects ( palace, "building", -1, tradingPostList, #MyPlayer, #CheckTitles, "trading_post");
					
					combinedList = $addlists ( marketplaceList, tradingPostList );
						
					foreach building in combinedList do
						begin
							if ($DistanceBetweenCoords($LocationOf( building ), tradingPostLocation) < distance)
								begin
									//$debugout(911, "Dwarfeh AI: Random coordinate for building trading post failed. Distance between coords:", $DistanceBetweenCoords($LocationOf( building ), tradingPostLocation), "Building coord:", $LocationOf( building ), "TradingPost coord:", tradingPostLocation);
									canBuildTradingPost = FALSE;
								end
						end
					
					//So we can technically build a trading post in this location, but do we have vision?
					if (canBuildTradingPost)
						begin
							if ($constructBuilding( palace, buildingName, buildingTitle, tradingPostLocation))
								begin
									if (palace's "build_dwarves")
										begin
											if ($canBuild(palace, "Ballista_Tower", "Ballista_Tower") && $canAffordBuilding( "Ballista_Tower", "Ballista_Tower", palace ))
												begin
													$AdjustPlayerData ( palace, "gold", -$getBuildingCost( "Ballista_Tower", "Ballista_Tower", palace ) );
													$SpawnUnit (palace , "Ballista_Tower" , tradingPostLocation, "clear" );													
												end
											else if ($canAffordBuilding( "GuardHouse1", "GuardHouse", palace ))
												begin
													$AdjustPlayerData ( palace, "gold", -$getBuildingCost( "GuardHouse1", "GuardHouse", palace ) );
													$SpawnUnit (palace , "GuardHouse1" , tradingPostLocation, "clear" );
												end													
										end	
									else if ($canAffordBuilding( "GuardHouse1", "GuardHouse", palace ))
										begin
											$AdjustPlayerData ( palace, "gold", -$getBuildingCost( "GuardHouse1", "GuardHouse", palace ) );
											$SpawnUnit (palace , "GuardHouse1" , tradingPostLocation, "clear" );
										end							
									//$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
									//$SpawnUnit (palace , "Trading_Post" , tradingPostLocation, "clear" );
								end
						end
				end
		end
	else
		begin
			$debugout(911, "Dwarfeh AI: Failed to generate trading post within map coordinates");
		end

end

//Dwarfeh
//Oh what have we done. This is some hacked together bullshit
//We have no fucking idea if we can place a building in a location with our current visibility. We can't check if a coordinate is visible. WE WANT TO BE HUMAN
//Solution? We can place a building in the Monster name, make it invisible, and disable it
//Then we search for the building with our vision. If we can find the damn thing it means we can build it.
//If we can't find it, we destroy it. Easy stuff right?
function constructBuilding(agent palace, string buildingName, string buildingTitle, coordinate buildingLocation) is boolean
declare
	agent tempBuilding;
	list buildingList;
begin
	

	tempBuilding = $SpawnUnit (palace , buildingName , buildingLocation, #Monster_Player, "maxhp",  $concatenate ( #ATTRIB_NotFlaggable, 1, #ATTRIB_NotSpellTarget, 1 ) );
	$ShowMinimap (tempBuilding, False);
	
	//No funny business. We are completely disabling the damn building in this temporary state and putting the type to be unknown
	tempBuilding's "type" = "unknown";
	if (tempBuilding's "title" == "Dwarven_settlement" || tempBuilding's "title" == "ballista_tower")
		begin
			tempBuilding's "enemytype" = "nothing";
		end
	if (tempBuilding's "title" == "guardhouse")
		tempBuilding's "enemytype" = "nothing";
	else
	if (tempBuilding's "title" == "outpost")
		begin
			$killThread( tempBuilding's "activeScript");
			$killThread( tempBuilding's "Guard_Function");
			$killThread ( tempBuilding's "Guard_Spawn_Function");
			$killThread( tempBuilding's "Tax_spawn");
			$killThread( tempBuilding's "peasant_spawn");
			tempBuilding's "title" = "outpost_hidden";
		end	
	
	//See remember when we changed the building type to unknown? Yeah now we get to search for it with our player's vision!
	$ListObjects(palace,"unknown", -1, buildingList, #Monster_Player );

	if ($listsize(buildingList) > 0)
		begin
			//This means we have visibility and can construct the building!
			//Let's destroy the current one
			//We don't want to use their own death script because it'll get real messy with outposts and everything. Let's just kill it and build our own
			$building_death(tempBuilding);
			
			$AdjustPlayerData ( palace, "gold", -$getBuildingCost( buildingName, buildingTitle, palace ) );
			$SpawnUnit (palace , buildingName , buildingLocation, "clear" );
			return TRUE;
		end
	else
		begin
			//We don't have the visibility to construct the building. Just kill it
			$building_death(tempBuilding);
			return FALSE;
		end
	
end

function performEnemyPlayer2BuildingUpgrade(agent palace)
declare
	list buildings, current;
	agent building, newPalace;
	coordinate palaceCoord;
begin

	
	//Palace upgrade section
	if ($canUpgradeBuilding(palace, palace) == TRUE)
		begin
			if (palace's "level" == 1)
				begin
					//$debugout(911, "Dwarfeh AI: Upgrading palace to level 2 for the price", $getBuildingUpgradePrice( palace, palace ));
					$AdjustPlayerData ( palace, "gold", -$getBuildingUpgradePrice( palace, palace ) );
					$ChangeUnitType( palace, "Palace2");
					$setAttribute ( palace, #ATTRIB_currentstagebuilt, 0);
					$adjustAttribute( palace,#attrib_MAXHP, 150);
					$UpgradeAgentAttributes ( palace );
					
					//No idea why it's needed but game will crash after a few seconds if it isn't ran after changing unit type
					$SetPalace( palace, $GetUnitPlayerNumber(palace));
						
					$palace_upgrade( palace );
				end
			else if (palace's "level" == 2)
				begin
					//$debugout(911, "Dwarfeh AI: Upgrading palace to level 3 for the price", $getBuildingUpgradePrice( palace, palace ));
					$AdjustPlayerData ( palace, "gold", -$getBuildingUpgradePrice( palace, palace ) );
					$ChangeUnitType( palace, "Palace3");
					$setAttribute ( palace, #ATTRIB_currentstagebuilt, 0);
					$adjustAttribute( palace,#attrib_MAXHP, 300);
					$UpgradeAgentAttributes ( palace );
					
					//No idea why it's needed but game will crash after a few seconds if it isn't ran after changing unit type
					$SetPalace( palace, $GetUnitPlayerNumber(palace));
							
					$palace_upgrade( palace );
				end
		end	
	
	//Remaining buildings upgrade section
	$ListObjects ( palace, "building", -1, buildings, #MyPlayer );
	current = $RemoveTitles ( buildings, "marketplace" );
	
	foreach building in current do
		begin
			if ($canUpgradeBuilding(building, palace))
				begin
					if (building's "level" == 1)
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingUpgradePrice( building, palace ) );
							$ChangeUnitType( building, "Marketplace2");
							$setAttribute ( building, #ATTRIB_currentstagebuilt, 0);
							$adjustAttribute( building,#attrib_MAXHP, 50);
							$UpgradeAgentAttributes ( building );
							
							$building_upgraded( building );
						end
					else if (building's "level" == 2)
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingUpgradePrice( building, palace ) );
							$ChangeUnitType( building, "Marketplace3");
							$setAttribute ( building, #ATTRIB_currentstagebuilt, 0);
							$adjustAttribute( building,#attrib_MAXHP, 50);
							$UpgradeAgentAttributes ( building );
							
							$building_upgraded( building );						
						end
				end
		end

	current = $RemoveTitles ( buildings, "Blacksmith" );
	
	foreach building in current do
		begin
			if ($canUpgradeBuilding(building, palace))
				begin
					if (building's "level" == 1)
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingUpgradePrice( building, palace ) );
							$ChangeUnitType( building, "Blacksmith2");
							$setAttribute ( building, #ATTRIB_currentstagebuilt, 0);
							$adjustAttribute( building,#attrib_MAXHP, 50);
							$UpgradeAgentAttributes ( building );
							
							$building_upgraded( building );
						end
					else if (building's "level" == 2)
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingUpgradePrice( building, palace ) );
							$ChangeUnitType( building, "Blacksmith3");
							$setAttribute ( building, #ATTRIB_currentstagebuilt, 0);
							$adjustAttribute( building,#attrib_MAXHP, 50);
							$UpgradeAgentAttributes ( building );
							
							$building_upgraded( building );						
