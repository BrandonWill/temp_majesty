									$ChangeUnitType( building, "Temple_Lunord2");
									$setAttribute ( building, #ATTRIB_currentstagebuilt, 0);
									$adjustAttribute( building,#attrib_MAXHP, 150);
									$UpgradeAgentAttributes ( building );
									
									$building_upgraded( building );
								end
						end
				end
		end

	current = $RemoveTitles ( buildings, "Library" );
	
	foreach building in current do
		begin
			if ($canUpgradeBuilding(building, palace) && $getTotalHeroLevel(palace) >= 100)
				begin
					//Library doesn't have levels so we base their "level" on their maxhp				
					if ($getAttribute( building ,#attrib_MAXHP) == 100)
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingUpgradePrice( building, palace ) );
							$ChangeUnitType( building, "Library2");
							$setAttribute ( building, #ATTRIB_currentstagebuilt, 0);
							$adjustAttribute( building,#attrib_MAXHP, 100);
							$UpgradeAgentAttributes ( building );
							
							$building_upgraded( building );
						end
				end
		end

	current = $RemoveTitles ( buildings, "Guardhouse" );
	
	foreach building in current do
		begin
			if ($canUpgradeBuilding(building, palace))
				begin
					//Guardhouse doesn't have levels so we base their "level" on their maxhp				
					if ($getAttribute( building ,#attrib_MAXHP) == 200)
						begin
							$AdjustPlayerData ( palace, "gold", -$getBuildingUpgradePrice( building, palace ) );
							$ChangeUnitType( building, "Guardhouse2");
							$setAttribute ( building, #ATTRIB_currentstagebuilt, 0);
							$adjustAttribute( building,#attrib_MAXHP, 75);
							$UpgradeAgentAttributes ( building );
							
							$building_upgraded( building );
						end
				end
		end

end


//Used to ensure one building gets to level 3
//Cost of performing the upgrade should be done prior to this method
function shouldUpgradeBuilding(agent building, agent palace) is boolean
declare
	list buildings;
	boolean hasLevelTwoBuilding, hasLevelThreeBuilding;
	agent potentialBuildingToUpgrade, buildingTemp;

begin
	$ListObjects ( palace, "building", -1, buildings, #MyPlayer, #CheckTitles, building's "title" );
	
	foreach buildingTemp in buildings do
		begin
			if (buildingTemp's "level" == 2)
				begin
					hasLevelTwoBuilding = TRUE;
				end
			else if (buildingTemp's "level" == 3)
				begin
					hasLevelThreeBuilding = TRUE;
				end
		end
	
	
	//$GetPlayerData ( palace, "gold" );
	//TODO: turn 20000 into an expression in globals to easily modify
	if (hasLevelThreeBuilding && $GetPlayerData ( palace, "gold" ) >= 20000)
		begin
			return TRUE;
		end
	//We want to see if there's a level 2 building and if that building is the building we're checking
	else if (hasLevelTwoBuilding && building's "level" == 2)
		begin
			if (hasLevelThreeBuilding && $GetPlayerData ( palace, "gold" ) >= 20000)
				begin
					return TRUE;
				end
			else if (hasLevelThreeBuilding == FALSE)
				begin
					return TRUE;
				end
			else
				begin
					//you only get here if you have level 3 building and not have 20k
					return FALSE;
				end
		end
	else if (hasLevelThreeBuilding == FALSE && hasLevelTwoBuilding == FALSE && building's "level" == 1)
		begin
			//Can afford to perform a building upgrade and no buildings have been upgraded
			return TRUE;
		end
	else
		begin
			//Our goal is to only upgrade 1 building unless we have 20k+ gold. We reach here if we don't
			return FALSE;
		end
	
end




