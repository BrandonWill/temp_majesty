///////////////////////////////////////////////////////////////////////////////
/// This is a prototype for the global container unit
//
prototype AIRoot()
declare
	list activeAgents;
	integer Done_setup;

	function KickoffFunction;
	function VictoryCondition;
	function VictoryCondition2;
	function SpecialSpawnScript; 	//These hold the functions (if any) that spawns a creature after a
	function SpecialSpawnScript2;	//certain amount of time (Like Dirgo in Brashnard)


	function UtilityScript; 		//This is a generic script for runtheading events. For instance, it is used in the demo
									//as the script that delays victory for x amount of time so that the player understands
									//that they won before the actual victory screen comes up.



	function MusicScript; 			//This is the thread that plays cd tracks
	integer	Track_Number; 			//This stores which track the game is going to be played next
	integer	Lair_extra_Delay; 		//This holds the time that is added onto a lair's spawnrate for every extra lair on a map
									//This is frequently overwritten on a per-quest basis in Epic_quest_scripts

	boolean	Quest_Flag_1;  			//Used for victory coditions in certain Epic Quest scenarios
	boolean	Quest_Flag_2;
	boolean Quest_Flag_3;
	boolean	Quest_Flag_4;
	boolean	Quest_Flag_5;
	boolean	Quest_Flag_6;
	boolean	Quest_Flag_7;
	boolean	Quest_Flag_8;
	boolean	Quest_Flag_9;
	boolean	Quest_Flag_10;
	boolean	Quest_Flag_11;
	boolean	Quest_Flag_12;
	boolean	Quest_Flag_13;
	boolean	Quest_Flag_14;
	boolean	Quest_Flag_15;
	boolean	Quest_Flag_16;
	boolean	Quest_Flag_17;
	boolean	Quest_Flag_18;
	boolean	Quest_Flag_19;
	boolean	Quest_Flag_20;

	boolean Message_Check_1;  		//Used to check whether to instantiate chained message flags in quests
	boolean	Message_Check_2;
	boolean	Message_Check_3;
	boolean	Message_Check_4;
	boolean Message_Check_5;

	boolean Lair_Delay_Override; 	//This is set to TRUE in freestyle games, where there is a minimum
									//time that MUST be added to all lair's spawnrates. This is because
									//there are times when there are no lairs onmap, but many offmap.

	coordinate end_coord;

	integer	Quest_Number; 			//This holds the number that corresponds to the current quest (1-indexed)
									//This is 0 if there is no Quest Running
 // list	Quest_Items;

	integer Survive_Limit; 			//This stores the amount of time that Freestyle survive time conditions need to last
									//it is in place because if we don't break the v.c. into chunks, we can overflow the 2mil
									//integer limit

	integer Victory_Score;  		// These integers are used to track victory / defeat scores in
	integer Defeat_Score;			// some missions. They are used on a quest by quest basis.

	integer day_counter;    		// This is used to keep track of how many days have elapsed in certain
									// quests.

	list AI_Reward_Flags; 			// Used by the AI player in SIEGE quest.

	boolean Permanent_Hostility;	// When this is TRUE, removing attack flags will no longer cause
									// a kingdom to revert to the neutral team.  They will be stuck
									// as a hostile team permanently.

	boolean Deathmatch_Rules;		// When this is TRUE, all the special deathmatch
									// Mods will be enforced.

	boolean Spawn_High_Level_Heroes;//If this is TRUE, then a special event script has been kicked off
									//that makes heroes spawn at high levels.

begin
end

///////////////////////////////////////////////////////////////////////////////
prototype hero ()

declare
	string type;
	string subtype;
	string title;
	string Original_type;

	integer percentageHPretreat;
	float Enemy_estimation;
	float self_estimation;

	integer Greed;
	integer Loyalty;
	integer Luck;

	integer critical_chance; 		// how likely a character is to deliver a killing blow

	Boolean resist_critical; 		// does this guy resist critical hits? (reduce their damage)
	Boolean Immune_to_poison;
	Boolean rangeIncrease; 			// does this hero get a attackrange bonus per level up?
	boolean criticalIncrease; 		// does this hero get a point of critical attack per level?

	agent leader;  					// Chris hackarama so heros can be controlled monsters

	integer Counter; 				// Exactly what it says it is.

	coordinate destination;

	string special_splat; 			// does this creature need a special splat player
									// when it hits its target?

	agent target; 					// this holds the target for any particular task
	agent BackTarget; 				// this is for those special times when a Hero has to remember their target
	string taskname; 				// used to tell what the hero is up to

	list hostiles; 					// this is a list used by the unit to help determine
									// targets and strength of enemies nearby

	string	Friend; 				//This holds subtype that this Hero is Friendly with

//	integer num_guards; 			// this is the number of guards this unit currently has
									// or the Number of Healers that are currently following and Healing it

	integer num_followers; 			// used by Priestess, and probably Cultist in regards to controlled monsters

	integer Reborn_Counter; 		//This holds how many free "go home and Ressurect"s the Healer has

	integer	Task_Number; 			//This typically holds Attrib references. For things like figuring out what a hero
									//wanted to buy at a blacksmith. They would store #Attrib_Weapon_Struct_Bonus in this case

	function StartingScript; 		//this holds the core start script that is inited with the agent. never change, because we rely
									//on this to always hold the agent's starting/basic behavior. this script is never 'executed'

	function basicscript; 			// this holds the basic decision tree a hero
									// always returns to checking
	function backscript;
	function activescript;			// this holds the current activity of the hero

	function evaluationScript; 		// holds the script which the hero uses to check nearby them fro danger

	function birthScript;  			// This script will be called once, when the unit is created;
	function IGdeathScript; 		// This script will be called once, when the unit is killed;
	function deathScript; 			// This script will be called once, when the unit is killed;

	agent home; 					// where the hero lives, set by the engine upon recruition

	agent palace; 					// the palace that this Hero is loyal to. set in the engine.

	boolean Raider_respond; 		// jim hackerama so heroes can become raider mosnters

	function teleportScript; 		// callback for the teleport spell

	function QuestScript; 			//This holds Quest-Specific logic

	// the distance a hero casts spells from
	integer castingrange;

  	integer PrimaryStat;

	integer num_picked_goodies;		//These may be stored in the engine

	integer	Upgrade_Armor_Chance;	//The chance that a hero will decide to think about upgrading their armor
  
	integer	Upgrade_Weapon_Chance;	//The chance that a hero will decide to think about upgrading their weapon
  
	integer	Poison_Weapon_Chance;	//The chance that a hero will decide to think about poisoning their weapon

	boolean	Special_Boolean; 		//This is quest specific. For instance, in WCurse, it is TRUE if a Hooligan has been found.

	string Enemytype;				// What the agent attacks, can be "Hero", "Monster" or "Nothing"
	integer attacktype;				// The agent's attack type
	string attack_action;			// The name of the action to perform when attacking
	string Special_attack_action; 	// This holds special attack actions (currently only used for Fire Balm)
									// Gets swapped with Attack_action for a duration, then swapped back again
	string cast_action;				// The name of the action to perform when casting a spell
	string Pickup_Action;			// The name of the action to perform when picking something up
	string Idle_Action;				// The name of the action to perform when going into idle

	// -- New MX additions below this line -- //
	function PlagueScript;
	function FreezeScript;
	function ShieldScript; 			//This is for the Frost Field spell

	boolean	Resists_Fire;
	
	// -- Dwarfeh AI additions below this line -- //
	
	integer cost; //unable to find correct #ATTRIB to pull cost so just integrating it here to make it easy for me to pull
	
	//////////////////////////////////////////////////////////////////////////////////////
	///////////////////////////////Majesty extras fields//////////////////////////////////
	//////////////////////////////////////////////////////////////////////////////////////
	
	integer custh1;
	integer custh2;
	integer custh3;
	integer custh4;
	integer custh5;
	integer custh6;
	integer custh7;
	integer custh8;
	integer custh9;
	integer custh0;
	
	function specFunc1; 
	function specFunc2;
	function specFunc3;
	function specFunc4;
	function specFunc5;
	function specFunc6;
	function specFunc7;
	function specFunc8;
	function Hold_Attack_Script;// used to store attack_object function. Possible optimization. Never executed, just for comparisons. // didn't work as expected :<
	
	boolean cusb1;
	boolean cusb2;
	boolean cusb3;
	boolean cusb4;
	boolean cusb5;
	boolean cusb6;
	boolean cusb7;
	
	list custl1;
	list custl2;
	list custl3;
	list custl4;
	list custl5;
	
	agent cusa1;
	agent cusa2;
	agent cusa3;
	agent cusa4;
	agent cusa5;
	agent cusa6;
	agent cusa7;
	
	string custs1;
	string custs2;
	string custs3;
	string custs4;
	string custs5;
	string custs6;	
	
