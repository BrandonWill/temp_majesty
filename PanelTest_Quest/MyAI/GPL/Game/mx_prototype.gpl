///////////////////////////////////////////////////////////////////////////////
prototype monster ()
// the mx monster prototype currently differs only in that it has an attribute to store
// a zoo flag agent that has been placed on it.

declare
	string type;
	string subtype;
	string title;
	string Original_type;

	string family; 					//This is used by buff-ing monsters, so they know which monster types to buff

	Boolean resist_critical; 		// does this guy resist critical hits? (reduce their damage)
	Boolean Immune_to_poison; 		// does poison not affect this monster
	boolean Familiar; 				// if this is true, a monster is someone's 'familiar'
	boolean Relentless; 			// will the monster relentlessly pursue its target (ignore range cheking)

	integer critical_chance; 		// how likely a monster is to deliver a killing blow

	coordinate destination;

	string special_splat; 			// does this creature need a special splat player
									// when it hits its target?

	agent target;
	list hostiles; 					// this a list used by the unit to help determine
									// targets and strength of enemies nearby

	string Friend; 					//This holds Hero Title that this Monster is friends with.

	coordinate	Coord_Home; 		//This holds the coord home for all monsters that use it (ie. Guardians and Offmap Sleepers)

	agent	Sleeper_Home; 			//This is for Sleepers. It holds their agent home.

	integer castingrange; 			// their spell range

	boolean isLeader; 				// used by war_party logic

	agent leader;

	integer num_followers; 			// used by war_party
	integer max_followers;

	boolean Raider_respond; 		// sets whether a raider will respond to being attacked
									// while in the midst of pounding on a building


	integer	Guardian_Mod; 			//This is multiplied times a Guardian Monster's sightrange to find the area that
									//they will pick a random coord to move to (around their home)

	function StartingScript; 		//this holds the core start script that is inited with the agent. never change, because we rely
									//on this to always hold the agent's starting/basic behavior
	function basicscript; 			// this holds the basic script the monster
									// always returns to when done with tasks
	function backscript;
	function activescript;

	function SleeperScript; 		//This holds the script that calls the unit back to its lair after a duration.

	function evaluationScript; 		// holds the script the monster uses to check nearby them for danger

	integer	Target_Item; 			//This is for Item_Hunters (like the Black Phantoms in Magic Ring
									//It holds the index of the item they are after

	boolean	Special_Boolean; 		//This is quest specific. For instance, in WCurse, it is TRUE if a Hooligan has been found.

	function teleportScript; 		// callback for the teleport spell

	function birthScript;  			// This script will be called once, when the unit is created;
	function IGdeathScript; 		// This script will be called once, when the unit is killed;
	function deathScript; 			// This script will be called once, when the unit is killed;

	integer counter;
	string Enemytype;

	integer attacktype;
	string attack_action;
	string idle_action;

// New MX stuff below this point //
	agent zoo_agent;
	function PlagueScript;
	function FreezeScript;
	function ShieldScript; 			//This is for the Frost Field spell

	boolean	Resists_Fire;
	
	// Dwarfeh AI stuff below this point //
	
	function player2AI;
	
//////////////////////////////////////////////////////////////////////////////////////
	///////////////////////////////Majesty extras fields//////////////////////////////////
	//////////////////////////////////////////////////////////////////////////////////////
	
	integer DangerLevel;			// this is to be used in future for target evaluation. instead of how it now works. ay too heavy in terms of perfomance
	integer MonsterLevel;
	integer MonsterExp; // keep it simple. Every 5 hits monster level up	
	
