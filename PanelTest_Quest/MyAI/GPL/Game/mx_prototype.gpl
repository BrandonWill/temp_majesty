///////////////////////////////////////////////////////////////////////////////
prototype Outpost ()

Declare
	string 	type;
	string 	subtype;
	string 	title;

	function activescript;
	integer level;

	agent Target;

	boolean in_danger;

	function Guard_Function;			//This Holds the Guard script that the Building constantly runs (after being set off by trigger)

	function Guard_Spawn_Function; 		//This holds the Spawn_Function for the Palace. It is on the agent because
										//it gets $RunThread-ed, so it needs to be persistent.

	list Waiting_Guards;				//This list holds Guards that have suspended their threads, and don't have targets
	list Guards;  						//List of this building's Guards

	list Waiting_Guardhouses; 			//This is a list of Guardhouses that are waiting for Guards.

	integer	Max_Guards; 				//Holds the Maximum number of Guards a palace can have
	integer	Num_Guards; 				//Keeps track of current number of Guards Palace has or is spawning

	integer	AttackType; 				//These are so the outpost can fire missiles.
	integer Ranged;
	integer	Strength;

	function Lived_In_Script; 			//Holds script that tells the character what to do here

	integer	Sleep_For;  				//This holds the duration a unit stays here for
	list Occupants;  					//List of all Occupants currently being held in this building

	list members; 						// all the current guild members
	// integer max_members;
	
	function spell_callback;			// special callback for spells (only used for supercharge for now)

	function tax_spawn;

	integer num_tax_collectors;
	integer max_tax_collectors;

	list tax_route;
	list tax_targets;

	list spawn_taxman_return_list; 		//These lists hold deadtax collectors tax attribs so
	list spawn_taxman_pickup_list; 		//that the next one gets spawned with the same Attribs

	integer tax_route_dead;

	function peasant_spawn;

	integer num_peasants;
	integer max_peasants;
	integer busy_peasants;

	list buildings_waiting;
	list buildings_under_construction;

	list Under_Const_In_Sight; 			//This is the list of all Buildings Under construction within sight

	integer	Vaporized_Gold; 			//Gold that has been vapoized when heroes spend money, etc.
	integer  troll_gold; 				// gold that is counting up to produce a troll somewhere in town

	agent Swarm_Target; 				//Holds the target that the Swarmers refer to/fill up when they want to combat wandering monsters

	function gnome_camp_spawner; 		// holds the function which spawns Gnome Camps

	Boolean Gambling_hall_building;
	boolean gazebo_building;

	integer Population_counter; 		// counts total # heroes recruited in town
	integer Waiting_population; 		// how much extras are waiting for housing

	integer num_deceased_heroes;

	integer total_buildings; 			// counts how many buildings have been built
	integer buildings_lately; 			// counts how many buildings have been built since the last sewer

	integer henchmen_dead_lately; 		//counts how many henchmen have died since last broken sewer main spawn

	integer fountain_buildings; 		// counts how many buildings towards a fountain have been built

	integer blacksmith_trips; 			// how many visits to the blacksmith?

	string  TaskName;

	integer heroes_to_upgrade; 			// how many heroes are needed to upgrade the palace

	integer num_resources;

	string 	Enemytype;

	function birthScript;  				// This script will be called once, when the unit is created;
	function IGdeathScript; 			// This script will be called once, when the unit is killed;
	function deathScript; 				// This script will be called once, when the unit is killed;

	function BirthScript2;

	function upgradescript;
	function upgradescript2;

begin
end

