prototype Guild()

declare
	string 	type;
	string 	subtype;
	string 	title;

	integer	Level; 						//This is what level the Guild is

	function Lived_In_Script; 			//Holds script that tells the character what to do here
	function Visited_Script; 			//This holds the script Heroes call when they are "Visiting" a building

